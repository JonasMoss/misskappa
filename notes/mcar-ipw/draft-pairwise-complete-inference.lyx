\begin_layout Proof
\begin_inset Argument 1
status open

\begin_layout Plain Layout
of Proposition 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:The-available-case"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\end_layout

\end_inset

We may write 
\begin_inset Formula 
\begin{eqnarray*}
E[l(X_{j},X_{k})M_{j}M_{k}] & = & \sum_{x^{\star}}p(x^{\star})E[l(X_{j},X_{k})M_{j}M_{k}\mid x^{\star}].
\end{eqnarray*}

\end_inset

Since we are dealing with missing data we may write 
\begin_inset Formula $p(x\mid x^{\star})=1[x\preceq x^{\star}]p(x\mid x^{\star})$
\end_inset

.
 The expectation on the right-hand side equals
\begin_inset Formula 
\[
E[l(X_{j},X_{k})M_{j}M_{k}\mid x^{\star}]=\sum_{x\preceq x^{\star}}l(x_{j},x_{k})1[x_{j}\neq\text{NA}]1[x_{k}\neq\text{NA}]p(x\mid x^{\star}).
\]

\end_inset

Now define 
\begin_inset Formula $C_{jk}(x^{\star})=\sum_{x\preceq x^{\star}}1[x_{j}\neq\text{NA}]1[x_{k}\neq\text{NA}]p(x\mid x^{\star}).$
\end_inset

 Then 
\begin_inset Formula $E[l(X_{j},X_{k})M_{j}M_{k}\mid x^{\star}]=l(x_{j}^{\star},x_{k}^{\star})C_{jk}(x^{\star}).$
\end_inset

 It follows that
\begin_inset Formula 
\[
\sum_{j<k}E[l(X_{ij}^{\star},X_{ik}^{\star})M_{ij}M_{ik}]=\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})C_{jk}(X^{\star})].
\]

\end_inset

The same analysis yields 
\begin_inset Formula $E[\sum_{j<k}M_{ij}M_{ik}]=E[C_{jk}(X^{\star})]$
\end_inset

.
 By the law of large numbers and the continuous mapping theorem we have have 
\begin_inset Formula $\hat{d}^{AC}\stackrel{a.s.}{\to}\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})C_{jk}(X^{\star})]/\sum_{j<k}E[C_{jk}(X^{\star})]$
\end_inset

.
 
\end_layout

\begin_layout Proof
We investigate 
\begin_inset Formula $\hat{d}_{C}^{AC}$
\end_inset

 next.
 Then
\begin_inset Formula 
\[
E[l(X_{ij},X_{i'k})M_{j}M_{k}]=\sum_{x^{\star}}\sum_{y^{\star}}p(x^{\star})E[l(X_{j}^{\star},Y_{k}^{\star})M_{j}N_{k}\mid x^{\star},y^{\star}]
\]

\end_inset


\begin_inset Formula 
\[
E[l(X_{j},Y_{k})M_{j}N_{k}\mid x^{\star},y^{\star}]=\sum_{x\preceq x^{\star}}\sum_{y\preceq y^{\star}}l(x_{j}^{\star},y_{k}^{\star})1[x_{j}\neq\text{NA}]1[y_{k}\neq\text{NA}]p(x\mid x^{\star})p(y\mid y^{\star})
\]

\end_inset

so defining 
\begin_inset Formula $C_{j}(x^{\star})=\sum_{x\preceq x^{\star}}1[x_{j}\neq\text{NA}]p(x\mid x^{\star})$
\end_inset

 we get 
\begin_inset Formula $E[l(X_{j},Y_{k})M_{j}N_{k}\mid x^{\star},y^{\star}]=C_{j}(x^{\star})C_{k}(y^{\star})l(x_{j},y_{k})$
\end_inset

 when and 
\begin_inset Formula 
\[
\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})M_{ij}M_{i'k}]=\sum_{j<k}E[C_{j}(X^{\star})C_{k}(Y^{\star})l(X_{j},Y_{k})].
\]

\end_inset

It follows that
\begin_inset Formula 
\[
E[\sum_{i,i'}\sum_{j<k}l(X_{ij}^{\star},X_{i'k}^{\star})M_{ij}M_{i'k}]=n(n-1)\sum_{j<k}E[l(X_{j},Y_{k})C_{j}(X^{\star})C_{k}(Y^{\star})]+n\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})C_{jk}(X^{\star})].
\]

\end_inset

On the other hand,
 
\begin_inset Formula 
\[
\sum_{i,i'}\sum_{j<k}M_{ij}M_{i'k}=n(n-1)\sum_{j<k}E[C_{j}(X^{\star})C_{k}(Y^{\star})]+n\sum_{j<k}E[C_{jk}(X^{\star})].
\]

\end_inset

 We ignore the negligible 
\begin_inset Formula $n$
\end_inset

 terms forming the fraction,
 and we get 
\begin_inset Formula $\hat{d}_{C}^{AC}\stackrel{a.s.}{\to}\sum_{j<k}E[l(X_{j},Y_{k})C_{j}(X^{\star})C_{k}(Y^{\star})]/\sum_{j<k}E[C_{j}(X^{\star})]E[C_{k}(Y^{\star})].$
\end_inset


\end_layout

\begin_layout Proof
In conclusion,
 
\begin_inset Formula 
\[
1-\frac{\hat{d}^{AC}}{\hat{d}_{C}^{AC}}\stackrel{a.s.}{\to}1-\left(\frac{\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})C_{jk}(X^{\star})]}{\sum_{j<k}E[C_{jk}(X^{\star})]}\right)/\left(\frac{\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})C_{j}(X^{\star})C_{k}(Y^{\star})]}{\sum_{j<k}E[C_{j}(X^{\star})]E[C_{k}(Y^{\star})]}\right),
\]

\end_inset

and this must be equal to 
\begin_inset Formula $1-\frac{\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})]}{\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})}$
\end_inset

 for the estimator to be consistent.
 The only obvious condition for this to happen is factorization in both 
\begin_inset Formula $\hat{d}^{AC}$
\end_inset

 and 
\begin_inset Formula $\hat{d}_{C}^{AC}$
\end_inset

,
 i.e.,
 
\begin_inset Formula $E[l(X_{j}^{\star},X_{k}^{\star})C_{jk}(X^{\star})]=E[l(X_{j}^{\star},X_{k}^{\star})]E[C_{jk}(X^{\star})]$
\end_inset

 and 
\begin_inset Formula $\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})C_{j}(X^{\star})C_{k}(Y^{\star})]=\sum_{j<k}E[C_{j}(X^{\star})C_{k}(Y^{\star})]$
\end_inset

.
 
\end_layout

\begin_layout Proof
Now suppose the raters are exchangeable and the missingness is,
 in fact,
 missing pairwise completely at random.
 Then 
\begin_inset Formula $C_{jk}(x^{\star})$
\end_inset

 and 
\begin_inset Formula $C_{j}(x^{\star})$
\end_inset

 are constant in 
\begin_inset Formula $x^{\star}$
\end_inset

 for each 
\begin_inset Formula $j,k$
\end_inset

 and 
\begin_inset Formula $E[l(X_{j}^{\star},X_{k}^{\star})]=E[l(X_{l}^{\star},X_{m}^{\star})]$
\end_inset

 for all rater indices.
 So we obtain
\begin_inset Formula 
\begin{eqnarray*}
1-\frac{\hat{d}^{AC}}{\hat{d}_{C}^{AC}} & \stackrel{a.s.}{\to} & 1-\left(\frac{\sum_{j<k}E[C_{jk}(X^{\star})]E[l(X_{j}^{\star},X_{k}^{\star})]}{\sum_{j<k}E[C_{jk}(X^{\star})]}\right)/\left(\frac{\sum_{j<k}E[C_{j}(X^{\star})]E[C_{k}(Y^{\star})]E[l(X_{j}^{\star},Y_{k}^{\star})]}{\sum_{j<k}E[C_{j}(X^{\star})]E[C_{k}(Y^{\star})]}\right),\\
 &  & 1-\left(\frac{\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})]}{\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})]}\right).
\end{eqnarray*}

\end_inset

Now suppose the raters aren't exchangeable.
 For the expressions for factorize we need both 
\begin_inset Formula $E[C_{jk}(X^{\star})]E[l(X_{j}^{\star},X_{k}^{\star})]=E[C_{jk}(X^{\star})E[l(X_{j}^{\star},X_{k}^{\star})]$
\end_inset

 and all 
\begin_inset Formula $E[C_{jk}(X^{\star})]E[l(X_{j}^{\star},X_{k}^{\star})]$
\end_inset

 to be equal across 
\begin_inset Formula $jk$
\end_inset

.
 Thus all 
\begin_inset Formula $C_{jk}(X^{\star})$
\end_inset

 must be equal.
 Since this must hold for chance agreement too,
 we require all 
\begin_inset Formula $C_{j}(x^{\star})$
\end_inset

 to be equal as well.
 This happens when the missingness is uniform PMCAR.
\end_layout

\begin_layout Proof
Suppose 
\begin_inset Formula $C_{j}(x^{\star})=c_{1}$
\end_inset

 is constant acroess 
\begin_inset Formula $j,x^{\star}$
\end_inset

 and 
\begin_inset Formula $C_{jk}(x^{\star})=C_{12}$
\end_inset

 is constant across 
\begin_inset Formula $j,k,x^{\star}$
\end_inset

.
 Then 
\begin_inset Formula 
\begin{eqnarray*}
1-\frac{\hat{d}^{AC}}{\hat{d}_{C}^{AC}} & \stackrel{a.s.}{\to} & 1-\left(\frac{\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})C_{jk}(X^{\star})]}{\sum_{j<k}E[C_{jk}(X^{\star})]}\right)/\left(\frac{\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})C_{j}(X^{\star})C_{k}(Y^{\star})]}{\sum_{j<k}E[C_{j}(X^{\star})]E[C_{k}(Y^{\star})]}\right),\\
 & = & 1-\left(\frac{\sum_{j<k}c_{12}E[l(X_{j}^{\star},X_{k}^{\star})]}{\sum_{j<k}c_{12}}\right)/\left(\frac{\sum_{j<k}c_{1}^{2}E[l(X_{j}^{\star},Y_{k}^{\star})]}{\sum_{j<k}c_{1}^{2}}\right),\\
 & = & 1-\frac{\sum_{j<k}E[l(X_{j}^{\star},X_{k}^{\star})]}{\sum_{j<k}E[l(X_{j}^{\star},Y_{k}^{\star})]}\\
 & = & \kappa_{C}
\end{eqnarray*}

\end_inset


\end_layout

