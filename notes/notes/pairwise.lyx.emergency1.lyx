\begin_layout Subsection
Variance and influence functions
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray*}
\psi(X_{i}) & = & \binom{R}{2}^{-1}\sum_{j<k}\pi_{jk}^{-1}R_{ij}R_{ik}(l(X_{ij},X_{ik})-d_{jk}),\\
\psi_{C}(X_{i}) & = & \binom{R}{2}^{-1}\sum_{j<k}\left[\pi_{j}^{-1}R_{ij}\left(E[l(X_{ij},X_{i'k})|X_{ij}]-d_{C,jk}\right)+\pi_{k}^{-1}R_{ik}\left(E[l(X_{i'j},X_{ik})|X_{ik}]-d_{C,jk}\right)\right],\\
\psi_{F}(X_{i}) & = & R^{-2}\sum_{j,k}\left[\pi_{j}^{-1}R_{ij}\left(E[l(X_{ij},X_{i'k})|X_{ij}]-d_{C,jk}\right)+\pi_{k}^{-1}R_{ik}\left(E[l(X_{i'j},X_{ik})|X_{ik}]-d_{C,jk}\right)\right].
\end{eqnarray*}

\end_inset

These influence functions involve unknown quantities we need to estimate.
 To make the estimators match the classical ones we will use 
\begin_inset Formula $E[l(X_{ij},X_{i'k})|X_{ij}]=\sum_{i'=1}^{n}l(X_{ij},X_{i'k})R_{i'k}\hat{\pi}_{k}^{-1}$
\end_inset

.
 The estimators of 
\begin_inset Formula $d_{C,jk}$
\end_inset

 and 
\begin_inset Formula $d_{jk}$
\end_inset

 can be precomputed and are equal to 
\begin_inset Formula $\hat{d}_{C,jk}=\sum_{i=1}^{n}\sum_{i'=1}^{n}\sum_{j<k}l(X_{ij},X_{i'k})R_{ij}R_{i'k}$
\end_inset

 and 
\begin_inset Formula $\hat{d}_{jk}=\sum_{i=1}^{n}\sum_{j<k}l(X_{ij},X_{ik})R_{ij}R_{ik}$
\end_inset

.
 Both are consistent and efficient due to the assumption of MCAR.
\end_layout

\begin_layout Standard
By solving the estimating equations generated by these influence functions we find 
\begin_inset Formula $\hat{d}$
\end_inset

 and 
\begin_inset Formula $\hat{d}_{C}$
\end_inset

 as defined above.
 Moreover,
 using the delta method (vdv,
 chap.
 25) along with 
\begin_inset Formula $\nabla(1-x/y)=(-y^{-1},y^{-2}x)$
\end_inset

,
 the efficient influence function for 
\begin_inset Formula $\kappa$
\end_inset

 is 
\begin_inset Formula 
\begin{eqnarray*}
\psi_{\kappa_{C}}(X_{i}) & = & -d_{C}^{-1}\psi(X_{i})+d_{C}^{-2}d\psi_{C}(X_{i}),\\
\psi_{\kappa_{F}}(X_{i}) & = & -d_{F}^{-1}\psi(X_{i})+d_{F}^{-2}d\psi_{F}(X_{i}),\\
\end{eqnarray*}

\end_inset

and solving the corresponding estimating equation yields 
\begin_inset Formula $\hat{\kappa}_{C}$
\end_inset

.
 The covariance matrix is 
\begin_inset Formula 
\[
\Gamma=\Cov([\psi(X),\psi_{C}(X),\psi_{F}(X),\psi_{\kappa_{C}}(X),\psi_{\kappa_{F}}(X),\psi_{BP}(X)).
\]

\end_inset


\end_layout

\begin_layout Proposition
Suppose the data is PMCAR with 
\begin_inset Formula $\pi_{ij}>0$
\end_inset

 and 
\begin_inset Formula $El^{2}(X_{ij},X_{ik})R_{i}R_{j}<\infty$
\end_inset

 for 
\begin_inset Formula $i,j,k$
\end_inset

.
 Them the vector 
\begin_inset Formula $\hat{\theta}=(\hat{d},\hat{d}_{C},\hat{\kappa}_{C})$
\end_inset

 satisfies 
\begin_inset Formula $\sqrt{n}(\hat{\theta}-\theta)\stackrel{d}{\to}N(0,\Gamma)$
\end_inset

.
 Moreover,
 
\begin_inset Formula $\hat{\Gamma}_{n}\to\Gamma$
\end_inset

 with probability 
\begin_inset Formula $1$
\end_inset

.
\end_layout

