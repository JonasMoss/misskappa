\hat{l}_{j\to k}^{V}(X_{i})=\frac{\sum_{i'=1}^{n}l(X_{ij},X_{i'k})R_{i'k}/\hat{\pi}_{k}}{\sum_{i'=1}^{n}R_{i'k}/\hat{\pi}_{k}}
\]

