\hat{l}_{j\to k}^{U}(X_{i})=\frac{\sum_{i'\neq i}l(X_{ij},X_{i'k})R_{i'k}/\hat{\pi}_{k}}{\sum_{i'\neq i}R_{i'k}/\hat{\pi}_{k}}
\]

