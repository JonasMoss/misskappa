 &  & \pi(x)^{y=y^{\star}}(1-\pi(x))^{y=\text{NA}}\\
\\p(x,y\mid\theta,y^{\star}) & = & p(y\mid x,y^{\star},\theta)p(x\mid y^{\star},\theta)\\
 & = & p(y\mid x,y^{\star},\theta)\frac{p(y^{\star}\mid x,\theta)}{p(y^{\star}\mid\theta)}p(x\mid\theta)\\
 & = & p(y\mid x,y^{\star},\theta)\frac{\theta(x)^{y^{\star}}(1-\theta(x))^{1-y^{\star}}}{p(y^{\star}\mid\theta)}p(x)\\
