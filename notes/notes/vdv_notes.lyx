\begin_layout Standard
Suppose 
\begin_inset Formula $\psi$
\end_inset

 is differentiable as above.
 By the Riesz representation theorem we have 
\begin_inset Formula $\dot{\psi}_{p}g=\left\langle \tilde{\psi}_{p},g\right\rangle _{L_{p}^{2}}$
\end_inset

 for some 
\begin_inset Formula $\tilde{\psi}_{p}\in L_{p}^{2}$
\end_inset

.
 Such functions are called 
\emph on
influence functions
\emph default
.
\end_layout

\begin_layout Definition
The efficient influence function is a function in 
\begin_inset Formula $\tilde{\psi}_{p}\in\overline{\text{span}T_{p}}$
\end_inset

 satisfying 
\begin_inset Formula $\dot{\psi}_{p}g=\left\langle \tilde{\psi}_{p},g\right\rangle _{L_{p}^{2}}$
\end_inset

.
\end_layout

\begin_layout Proposition
Let 
\begin_inset Formula $\psi$
\end_inset

 be differentiable.
 Then the efficient influence function exists and is unique.
\end_layout

\begin_layout Proof
Let 
\begin_inset Formula $\check{\psi}_{p}$
\end_inset

 be any influence function.
 Let 
\begin_inset Formula $\Pi$
\end_inset

 be the projection onto 
\begin_inset Formula $\overline{\text{span}T_{p}}$
\end_inset

.
 Then 
\begin_inset Formula 
\begin{eqnarray*}
\left\langle \check{\psi}_{p},g\right\rangle  & = & \left\langle \Pi\check{\psi}_{p}+(I-\Pi)\check{\psi}_{p},g\right\rangle ,\\
 & = & \left\langle \Pi\check{\psi}_{p},g\right\rangle +\left\langle (I-\Pi)\check{\psi}_{p},g\right\rangle ,\\
 & = & \left\langle \Pi\check{\psi}_{p},g\right\rangle +\left\langle \check{\psi}_{p},(I-\Pi)g\right\rangle ,\\
 & = & \left\langle \Pi\check{\psi}_{p},g\right\rangle .
\end{eqnarray*}

\end_inset

Moreover,
 
\begin_inset Formula $\left\langle \Pi(\check{\psi}_{p}^{1}-\check{\psi}_{p}^{2}),g\right\rangle =0,$
\end_inset

and since they are equal 
\begin_inset Formula $T_{p}$
\end_inset

 they are equal on 
\begin_inset Formula $\overline{\text{span}T_{p}}$
\end_inset

.
\end_layout

