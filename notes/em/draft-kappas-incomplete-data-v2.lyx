\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray}
\sqrt{n}(\hat{\kappa}-\kappa) & \stackrel{d}{\to} & N(0,(\nabla_{\theta}\kappa)^{T}\Sigma_{\theta}\nabla_{\theta}\kappa),\label{eq:kappa-theta-limit}\\
