\begin_layout Title
Comment on Falotico and Quatto (2014)
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
p_{F}(P,Q)=E_{X\sim Pf\times Qf}(X_{1}=X_{2})=\frac{1}{2}\tr(ff^{T})+\frac{1}{4}\tr(ff^{T}P^{T}Q)+\frac{1}{4}(ff^{T}Q^{T}P)
\]

\end_inset

Let 
\begin_inset Formula $P,Q$
\end_inset

 be independently sampled from the uniform distribution over the permutation
 matrices, and consider 
\begin_inset Formula $Ep_{F}(P,Q)$
\end_inset

.
 Since the trace is linear, we can compute
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
EP^{T}Q=C^{-4}11^{T}11^{T}=C^{-2}11^{T}.
\]

\end_inset

It follows that
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{1}{4}E(\tr(ff^{T}Q^{T}P))=\frac{1}{4}C^{-2},
\]

\end_inset

hence
\begin_inset Formula 
\[
E[p_{F}(P,Q)]=\frac{1}{2}p_{F}+\frac{1}{2}C^{-1}.
\]

\end_inset

The resulting agreement coefficient becomes 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{p_{a}-E[p_{F}(P,Q)]}{1-E[p_{F}(P,Q)]}=\frac{p_{a}-(\frac{1}{2}p_{F}+\frac{1}{2}C^{-1})}{1-(\frac{1}{2}p_{F}+\frac{1}{2}C^{-1})}
\]

\end_inset


\end_layout

