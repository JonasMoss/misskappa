\begin_layout Subsection*
Proof of the Knowledge Coefficient Theorem on p.
 
\begin_inset CommandInset ref
LatexCommand pageref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 
\begin_inset CommandInset label
LatexCommand label
name "subsec:proof of knowledge theorem"

\end_inset

 
\end_layout

\begin_layout Standard
Recall that 
\begin_inset Formula $W$
\end_inset

 is a matrix 
\begin_inset Formula $C\times C$
\end_inset

 matrix of agreement weights, that is, a symmetric matrix whose elements
 
\begin_inset Formula $W_{ir}$
\end_inset

 satisfy 
\begin_inset Formula $1\geq W_{ir}$
\end_inset

 with 
\begin_inset Formula $W_{ir}=1$
\end_inset

 if and only if 
\begin_inset Formula $i=r$
\end_inset

.
 We simplify our notation by considering two judges only.
 Define 
\begin_inset Formula $p_{wa}(r_{1},r_{2})$
\end_inset

 and 
\begin_inset Formula $p_{wc}(r_{1},r_{2})$
\end_inset

 as the the probability of (chance) agreement restricted to the two judges
 
\begin_inset Formula $r_{1}$
\end_inset

 and 
\begin_inset Formula $r_{2}$
\end_inset

.
 Clearly, 
\begin_inset Formula $p_{wa}=\binom{R}{2}^{-1}\sum_{r_{1}<r_{2}}p_{wa}(r_{1},r_{2})$
\end_inset

 and 
\begin_inset Formula $p_{wc}=\binom{R}{2}^{-1}\sum_{r_{1}<r_{2}}p_{wc}(r_{1},r_{2})$
\end_inset

.
\end_layout

\begin_layout Standard
In the following lemma, we will view probability mass functions as vectors.
 That is, we will view e.g.
 
\begin_inset Formula $p$
\end_inset

 as the vector in 
\begin_inset Formula $\mathbb{R}^{C}$
\end_inset

 whose 
\begin_inset Formula $i$
\end_inset

th element is 
\begin_inset Formula $p(x_{i})$
\end_inset

.
 This will greatly simplify our notation.
 
\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:expression lemma"

\end_inset

The following is true.
\end_layout

\begin_deeper
\begin_layout Enumerate
The weighted agreement between 
\begin_inset Formula $r_{1}$
\end_inset

 and 
\begin_inset Formula $r_{2}$
\end_inset

, 
\begin_inset Formula $p_{wa}(r_{1},r_{2})$
\end_inset

, equals 
\begin_inset Formula 
\begin{multline}
E[s_{r_{1}}s_{r_{2}}]+(E[s_{r_{1}}]-E[s_{r_{1}}s_{r_{2}}])t^{T}Wq_{r_{2}}+(E[s_{r_{2}}]-E[s_{r_{1}}s_{r_{2}}])q_{r_{1}}^{T}Wt\\
+(1-E[s_{r_{1}}]-E[s_{r_{2}}]+E[s_{r_{1}}s_{r_{2}}])q_{r_{1}}^{T}Wq_{r_{2}}.\label{eq:p_wa_expression}
\end{multline}

\end_inset


\end_layout

\begin_layout Enumerate
The weighted chance agreement between 
\begin_inset Formula $r_{1}$
\end_inset

 and 
\begin_inset Formula $r_{2}$
\end_inset

, or 
\begin_inset Formula $p_{wc}(r_{1},r_{2})$
\end_inset

, equals
\begin_inset Formula 
\begin{multline}
E[s_{r_{1}}]E[s_{r_{2}}]t^{T}Wt+(E[s_{i_{1}r_{1}}]-E[s_{r_{1}}]E[s_{r_{2}}])t^{T}Wq_{r_{2}}+(E[s_{r_{2}}]-E[s_{r_{1}}]E[s_{r_{2}}])q_{r_{1}}^{T}Wt\\
+(1-E[s_{r_{1}}]-E[s_{r_{2}}]+E[s_{r_{1}}]E[s_{r_{2}}])q_{r_{1}}^{T}Wq_{r_{2}}.\label{eq:p^C_wa_expression}
\end{multline}

\end_inset


\end_layout

\begin_layout Enumerate
Finally, the weighted chance agreement between 
\begin_inset Formula $r_{1}$
\end_inset

 and 
\begin_inset Formula $r_{2}$
\end_inset

 can be written in terms of the marginal distributions and the weighting
 matrix,
\begin_inset Formula 
\begin{equation}
p_{wc}(r_{1},r_{2})=\sum_{x_{1},x_{2}}w(x_{1},x_{2})p_{r_{1}}(x_{1})p_{r_{2}}(x_{2})=p_{r_{1}}^{T}Wp_{r_{2}}.\label{eq:eq:p^F_wa_expression}
\end{equation}

\end_inset


\end_layout

\end_deeper
\begin_layout Proof

\series bold
(i)
\series default
 We will make use the following expression for 
\begin_inset Formula $p_{wa}(r_{1},r_{2})$
\end_inset

:
\begin_inset Formula 
\[
p_{wa}(r_{1},r_{2})=\sum_{x^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})p(x_{r_{1}}\mid s,x^{\star})p(x_{r_{2}}\mid s,x^{\star})t(x^{\star}).
\]

\end_inset

Recall that 
\begin_inset Formula $x^{\star}$
\end_inset

 is the true rating, 
\begin_inset Formula $x_{1}$
\end_inset

 is the rating by judge 
\begin_inset Formula $1$
\end_inset

, and 
\begin_inset Formula $x_{2}$
\end_inset

 the rating by judge 
\begin_inset Formula $2$
\end_inset

, and the expression for the full guessing model, 
\begin_inset Formula $p(x\mid s,x^{\star})=s_{r}1[x=x^{\star}]+(1-s_{r})q_{r}(x)$
\end_inset

 of formula 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:full guessing model"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 We expand the right hand side of the expression for 
\begin_inset Formula $p_{wa}(r_{1},r_{2})$
\end_inset

 above to obtain
\end_layout

\begin_layout Proof
\begin_inset Formula 
\begin{align*}
p_{wa}(r_{1},r_{2}) & =\sum_{x^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}s_{r_{2}}t(x^{\star})1[x_{1}=x_{2}=x^{\star}] & (=A)\\
 & +\sum_{x^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}(1-s_{r_{2}})t(x^{\star})1[x_{1}=x^{\star}]q_{r_{2}}(x_{2}) & (=B)\\
 & +\sum_{x^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{2}}(1-s_{r_{2}})q_{r_{1}}(x_{1})t(x^{\star})1[x_{2}=x^{\star}] & (=C)\\
 & +\sum_{x^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})(1-s_{r_{1}})(1-s_{r_{2}})q_{r_{1}}(x_{1})q_{r_{2}}(x_{2})t(x^{\star}) & (=D)
\end{align*}

\end_inset


\end_layout

\begin_layout Proof
Now we sum over 
\begin_inset Formula $x^{\star},x_{1},x_{2}$
\end_inset

 for each of 
\begin_inset Formula $(A)-(D)$
\end_inset

.
 Starting with 
\begin_inset Formula $(A)$
\end_inset

, recall that 
\begin_inset Formula $w(x,x)=1$
\end_inset

 for all 
\begin_inset Formula $x$
\end_inset

.
 Thus
\begin_inset Formula 
\begin{eqnarray*}
A & = & \sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})[s_{r_{1}}s_{r_{2}}t(x^{\star})1[x_{1}=x_{2}=x^{\star}],\\
 & = & s_{r_{1}}s_{r_{2}}.
\end{eqnarray*}

\end_inset

Now consider 
\begin_inset Formula $(B)$
\end_inset

, where we must recall that 
\begin_inset Formula $W$
\end_inset

, the weighting matrix, is the matrix with elements 
\begin_inset Formula $W_{ir}=w(x_{i},x_{r}$
\end_inset

).
 
\begin_inset Formula 
\begin{eqnarray*}
B & = & \sum_{x^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}(1-s_{r_{2}})t(x^{\star})1[x_{1}=x^{\star}]q_{r_{2}}(x_{2}),\\
 & = & \sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}(1-s_{r_{2}})t(x_{1})q_{r_{2}}(x_{2}),\\
 & = & s_{r_{1}}(1-s_{r_{2}})t^{T}Wq_{r_{2}}.
\end{eqnarray*}

\end_inset

Likewise, 
\begin_inset Formula $C=s_{r_{2}}(1-s_{r_{2}})q_{r_{1}}^{T}Wt$
\end_inset

 and 
\begin_inset Formula $D=(1-s_{r_{1}})(1-s_{r_{2}})q_{r_{1}}^{T}Wq_{r_{2}}$
\end_inset

.
 
\end_layout

\begin_layout Proof
Summing over 
\begin_inset Formula $x_{1},x_{2}$
\end_inset

, the expression becomes 
\begin_inset Formula 
\begin{eqnarray*}
 & = & s_{r_{1}}s_{r_{2}}+s_{r_{1}}(1-s_{r_{2}})q_{r_{1}}^{T}Wt+s_{r_{2}}(1-s_{r_{2}})q_{r_{1}}(x_{1})t(x_{2})\\
 &  & +(1-s_{r_{1}})(1-s_{r_{2}})q_{r_{1}}^{T}Wq_{r_{2}},
\end{eqnarray*}

\end_inset

and 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:p_wa_expression"
plural "false"
caps "false"
noprefix "false"

\end_inset

 follows from taking expectations over 
\begin_inset Formula $s_{r_{1}},s_{r_{2}}$
\end_inset

.
\end_layout

\begin_layout Proof

\series bold
(ii)
\series default
 We proceed in the same way as we did in (i).
 
\begin_inset Formula 
\begin{eqnarray*}
p_{wc}(r_{1},r_{2}\mid s_{r_{1}},s_{r_{2}}) & = & \sum_{x_{1},x_{2}}w(x_{r_{1}},x_{r_{2}})p(x_{r_{1}}\mid s_{r_{1}})p(x_{r_{2}}\mid s_{r_{1}})\\
 & = & \sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1},x_{2}}w(x_{r_{1}},x_{r_{2}})p(x_{r_{1}}\mid s_{r_{1}},x_{1}^{\star})p(x_{r_{2}}\mid s_{r_{2}},x_{2}^{\star})t(x_{1}^{\star})t(x_{2}^{\star})
\end{eqnarray*}

\end_inset

Again, we expand this expression to obtain
\end_layout

\begin_layout Proof
\begin_inset Formula 
\begin{align*}
p_{wc}(r_{1},r_{2}\mid s_{r_{1}},s_{r_{2}}) & =\sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}s'_{r_{2}}t(x_{1}^{\star})t(x_{2}^{\star})1[x_{1}=x_{1}^{\star}]1[x_{2}=x_{2}^{\star}] & (=A)\\
 & +\sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}(1-s{}_{r_{2}})t(x_{1}^{\star})1[x_{1}=x^{\star}]q_{r_{2}}(x_{2})t(x_{2}^{\star}) & (=B)\\
 & +\sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{2}}(1-s{}_{r_{1}})q_{r_{1}}(x_{1})t(x_{2}^{\star})1[x_{2}=x^{\star}]t(x_{1}^{\star}) & (=C)\\
 & +\sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})(1-s_{r_{1}})(1-s{}_{r_{2}})q_{r_{1}}(x_{1})q_{r_{2}}(x_{2})t(x_{1}^{\star})t(x_{2}^{\star}) & (=D)
\end{align*}

\end_inset

The main difference from (i) is in (A), 
\begin_inset Formula 
\begin{eqnarray*}
 &  & \sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}s{}_{r_{2}}t(x_{1}^{\star})t(x_{2}^{\star})1[x_{1}=x_{1}^{\star}]1[x_{2}=x_{2}^{\star}]\\
 & = & s_{r_{1}}s'_{r_{2}}t^{T}Wt.
\end{eqnarray*}

\end_inset

Let's consider (B) too:
\begin_inset Formula 
\begin{eqnarray*}
 &  & \sum_{x_{1}^{\star}}\sum_{x_{2}^{\star}}\sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}(1-s{}_{r_{2}})t(x_{1}^{\star})1[x_{1}=x^{\star}]q_{r_{2}}(x_{2})t(x_{2}^{\star}),\\
 & = & \sum_{x_{1}}\sum_{x_{2}}w(x_{1},x_{2})s_{r_{1}}(1-s{}_{r_{2}})t(x_{1})q_{r_{2}}(x_{2}),\\
 & = & s_{r_{1}}(1-s_{r_{2}})t^{T}Wq_{r_{2}}.
\end{eqnarray*}

\end_inset

(C) and (D) can be calculated in the same way.
 After taking expectations with respect to independent 
\begin_inset Formula $s_{r_{1}},s_{r_{2}}$
\end_inset

, we find the expression for 
\begin_inset Formula $p_{wc}(r_{1},r_{2})$
\end_inset

 in the statement of the Lemma.
\end_layout

\begin_layout Proof

\series bold
(iii)
\series default
 The expression for 
\begin_inset Formula $p_{wc}$
\end_inset

 in terms of 
\begin_inset Formula $p_{r_{1}},p_{r_{2}}$
\end_inset

is trivial.
\end_layout

