\begin_layout Subsection*
Exact variance of 
\begin_inset Formula $\hat{p}_{a}$
\end_inset

 and 
\begin_inset Formula $\hat{\nu}_{BP}$
\end_inset

 
\begin_inset CommandInset label
LatexCommand label
name "subsec:variance of p_a"

\end_inset


\end_layout

\begin_layout Standard
In this section we derive the exact, non-asymptotic variance of 
\begin_inset Formula $\hat{p}_{a}$
\end_inset

 and the Brennan–Prediger coefficient 
\begin_inset Formula $\hat{\nu}_{BP}$
\end_inset

.
\end_layout

\begin_layout Proposition
\begin_inset CommandInset label
LatexCommand label
name "prop:exact variane"

\end_inset

The variance of 
\begin_inset Formula 
\[
\hat{p}_{a}=n^{-1}\sum_{i=1}^{n}\binom{R}{2}^{-1}\sum_{r>r'}1[X_{ir}=X_{ir'}]
\]

\end_inset

is 
\begin_inset Formula $\Var\hat{p}_{a}=n^{-1}(p_{2a}-p_{a}^{2})$
\end_inset

.
 Here 
\begin_inset Formula 
\[
p_{2a}=\binom{R}{2}^{-2}\sum_{r_{1}>r_{1}'}\sum_{r_{2}>r_{2}'}\mu_{r_{1}r_{1}'r_{2}r_{2}'},
\]

\end_inset

and 
\begin_inset Formula 
\[
\mu_{r_{1}r_{1}'r_{2}r_{2}'}=P(X_{ir_{1}}=X_{ir_{1}'},X_{ir_{2}}=X_{ir_{2}'}).
\]

\end_inset


\end_layout

\begin_layout Proof
Define 
\begin_inset Formula $\mu_{rr}'=P(X_{ir}=X_{ir'})$
\end_inset

.
 Then 
\begin_inset Formula 
\[
p_{a}=\binom{R}{2}^{-1}\sum_{r>r'}P(X_{ir}=X_{ir'})=\binom{R}{2}^{-1}\sum_{r>r'}\mu_{rr}'
\]

\end_inset

by definition and thus,
\begin_inset Formula 
\[
p_{a}^{2}=\left[\binom{R}{2}^{-1}\sum_{r>r'}\mu_{rr}'\right]^{2}=\binom{R}{2}^{-2}\sum_{r_{1}>r_{1}'}\sum_{r_{2}>r_{2}'}\mu_{r_{1}r_{1}'}\mu_{r_{2}r_{2}'}.
\]

\end_inset

To find the variance we must calculate
\begin_inset Formula 
\begin{eqnarray*}
E\hat{p}_{a}^{2} & = & n^{-2}\binom{R}{2}^{-2}\sum_{i_{1},i_{2}}\sum_{r_{1}>r_{1}'}\sum_{r_{2}>r_{2}'}E\left\{ 1[X_{i_{1}r_{1}}=X_{i_{1}r_{1}'}]1[X_{i_{2}r_{2}}=X_{i_{2}r_{2}'}]\right\} ,\\
 & = & n^{-2}\binom{R}{2}^{-2}\sum_{i_{1},i_{2}}\sum_{r_{1}>r_{1}'}\sum_{r_{2}>r_{2}'}P(X_{i_{1}r_{1}}=X_{i_{1}r_{1}'},X_{i_{2}r_{2}}=X_{i_{2}r_{2}'}).
\end{eqnarray*}

\end_inset

Looking at 
\begin_inset Formula $P(X_{i_{1}r_{1}}=X_{i_{1}r_{1}'},X_{i_{2}r_{2}}=X_{i_{2}r_{2}'})$
\end_inset

, we notice that, if 
\begin_inset Formula $i_{1}\neq i_{2}$
\end_inset

 it equals 
\begin_inset Formula $P(X_{i_{1}r_{1}}=X_{i_{1}r_{1}'},X_{i_{2}r_{2}}=X_{i_{2}r_{2}'})=\mu_{r_{1}r_{1}'}\mu_{r_{2}r_{2}'}$
\end_inset

 due to independence.
 This happens 
\begin_inset Formula $n(n-1)$
\end_inset

 times when we sum over 
\begin_inset Formula $i_{1},i_{2}$
\end_inset

.
 On the other hand, if 
\begin_inset Formula $i_{1}=i_{2}$
\end_inset

, it equals 
\begin_inset Formula $\mu_{r_{1}r_{1}'r_{2}r_{2}'}$
\end_inset

.
 This happens 
\begin_inset Formula $n$
\end_inset

 times when we sum over 
\begin_inset Formula $i_{1},i_{2}$
\end_inset

.
\end_layout

\begin_layout Proof
It follows that 
\begin_inset Formula 
\[
E\hat{p}_{a}^{2}=(1-n^{-1})p_{a}^{2}+n^{-1}\binom{R}{2}^{-2}\sum_{r_{1}>r_{1}'}\sum_{r_{2}>r_{2}'}\mu_{r_{1}r_{1}'r_{2}r_{2}'},
\]

\end_inset

and the variance equals
\begin_inset Formula 
\[
\Var\hat{p}_{a}=n^{-1}(E\hat{p}_{a}^{2}-p_{a}^{2})=n^{-1}(p_{2a}-p_{a}^{2}),
\]

\end_inset

as claimed.
\end_layout

\begin_layout Standard
The sample Brennan–Prediger coefficient 
\begin_inset Formula $\hat{\nu}_{BP}=(\hat{p}_{a}-C^{-1})/(1-C^{-1})$
\end_inset

 is easy to deal with, as it's a linear function of 
\begin_inset Formula $\hat{p}_{a}$
\end_inset

.
 As shown in Proposition 
\begin_inset CommandInset ref
LatexCommand pageref
reference "prop:exact variane"
plural "false"
caps "false"
noprefix "false"

\end_inset

, the sample agreement 
\begin_inset Formula $\hat{p}_{a}$
\end_inset

 has exact variance 
\begin_inset Formula $\Var(\hat{p}_{a})=n^{-1}(p_{2a}-p_{a}^{2})$
\end_inset

, where 
\begin_inset Formula $p_{a}$
\end_inset

 is the true agreement and
\begin_inset Formula $p_{2a}=\binom{R}{2}^{-2}\sum_{r_{1}>r_{1}'}\sum_{r_{2}>r_{2}'}P(X_{ir_{1}}=X_{ir_{1}'},X_{ir_{2}}=X_{ir_{2}'}).$
\end_inset

 The value of 
\begin_inset Formula $p_{2a}$
\end_inset

 is easy to estimate using the sample estimator 
\begin_inset Formula $\hat{p}_{2a}$
\end_inset

.
 Moreover, the expectation of 
\begin_inset Formula $\hat{p}_{a}^{2}$
\end_inset

 is 
\begin_inset Formula $\frac{n-1}{n}p_{a}^{2}+\frac{1}{n}p_{2a}$
\end_inset

, hence a debiased estimator of 
\begin_inset Formula $n^{-1}(p_{2a}-p_{a}^{2})$
\end_inset

 is
\begin_inset Formula 
\[
\hat{\Var}\hat{p}_{a}=(n-1)^{-1}(\hat{p}_{2a}-\hat{p}_{a}^{2}),
\]

\end_inset

provided 
\begin_inset Formula $\hat{p}_{2a}>\hat{p}_{a}^{2}$
\end_inset

.
 This inequality is rarely broken, even in small samples.
\end_layout

\begin_layout Standard
Using the expression for 
\begin_inset Formula $\Var\hat{p}_{a}$
\end_inset

, it follows that the exact variance of the estimated Brennan–Prediger coefficie
nt 
\begin_inset Formula $\hat{\nu}$
\end_inset

 is 
\begin_inset Formula 
\begin{equation}
\Var\hat{\nu}=n^{-1}(p_{2a}-p_{a}^{2})\frac{C^{2}}{(C-1)^{2}},\label{eq:Brennan-Prediger variance}
\end{equation}

\end_inset

and 
\begin_inset Formula $\sqrt{n}(\hat{\nu}-\nu)$
\end_inset

 is asymptotically normal by the delta method.
 A natural plug-in estimator of 
\begin_inset Formula $\Var\hat{\nu}$
\end_inset

 is then
\begin_inset Formula 
\[
\hat{\Var}\hat{\nu}=(n-1)^{-1}(\hat{p}_{2a}-\hat{p}_{a}^{2})\frac{C^{2}}{(C-1)^{2}}
\]

\end_inset

The usual estimator of 
\begin_inset Formula $\Var\hat{p}_{a}$
\end_inset

 is 
\begin_inset Formula $n^{-1}(n-1)^{-1}\sum(\hat{p}_{a}(i)-\hat{p}_{a})^{2}$
\end_inset

, where 
\begin_inset Formula $\hat{p}_{a}(i)$
\end_inset

 is the probability of agreement restricted to the 
\begin_inset Formula $i$
\end_inset

th item.
 This estimator is consistent since 
\begin_inset Formula $\hat{p}_{a}=\frac{1}{n}\sum_{i=1}^{n}\hat{p}_{a}(i)$
\end_inset

.
 We would recommend this estimator of the variance over the plug-in estimator
 for three reasons.
 First, it performs better than the plugin estimator in several scenarios.
 Second, it is always non-negative, being zero if and only if all 
\begin_inset Formula $\hat{p}_{ai}$
\end_inset

s are equal.
 Finally, it is considerably less computationally expensive.
 
\end_layout

