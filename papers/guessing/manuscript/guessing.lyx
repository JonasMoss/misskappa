\end_inset


\end_layout

\begin_layout Proof
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Proof of Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Proof

\series bold
(i).

\series default
 Assume all guessing distributions are equal, i.e., 
\begin_inset Formula $q_{r}(x)=q(x)$
\end_inset

.
 We wish to show that the following are equivalent
\begin_inset Formula 
\begin{equation}
q(x)=t(x),\quad p(x)=t(x),\quad q(x)=p(x).\label{eq:equivalence equaitons}
\end{equation}

\end_inset

To do this, recall the marginal univariate model 
\begin_inset Formula $p(x\mid s)=s_{r}t(x)+(1-s_{r})q(x).$
\end_inset

 Take expectations over 
\begin_inset Formula $s$
\end_inset

 to obtain, with 
\begin_inset Formula $\alpha=R^{-1}\sum_{r}E(s_{r}),$
\end_inset


\begin_inset Formula 
\begin{equation}
p(x)=\alpha t(x)+(1-\alpha)q(x).\label{eq:marginal univariate model}
\end{equation}

\end_inset

It immediately follows that the expressions in 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:equivalence equaitons"
plural "false"
caps "false"
noprefix "false"

\end_inset

 are equivalent.
\end_layout

\begin_layout Proof
Let's proceed to prove the rest of (i).
 If all guessing distributions are equal to the true distribution, then
 the formula 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:p_wa_expression"
plural "false"
caps "false"
noprefix "false"

\end_inset

 can be written as
\begin_inset Formula 
\begin{multline*}
p_{wa}(r_{1},r_{2})=E[s_{r_{1}}s_{r_{2}}]+(E[s_{r_{1}}]-E[s_{r_{1}}s_{r_{2}}])t^{T}Wt+(E[s_{r_{2}}]-E[s_{r_{1}}s_{r_{2}}])t^{T}Wt\\
+(1-E[s_{r_{1}}]-E[s_{r_{2}}]+E[s_{r_{1}}s_{r_{2}}])t^{T}Wt.
\end{multline*}

\end_inset

Some of the terms cancel, leaving
\end_layout

\begin_layout Proof
\begin_inset Formula 
\[
p_{wa}(r_{1},r_{2})=E[s_{r_{1}}s_{r_{2}}](1-t^{T}Wt)+t^{T}Wt.
\]

\end_inset

Moreover, the formula for 
\begin_inset Formula $p_{wc}(r_{1},r_{2})$
\end_inset

 can be simplified:
\begin_inset Formula 
\begin{multline*}
p_{wc}(r_{1},r_{2})=E[s_{r_{1}}]E[s_{r_{2}}]t^{T}Wt+(E[s_{r_{1}}]-E[s_{r_{1}}]E[s_{r_{2}}])t^{T}Wt+(E[s_{r_{2}}]-E[s_{r_{1}}]E[s_{r_{2}}])t^{T}Wt\\
+(1-E[s_{r_{1}}]-E[s_{r_{2}}]+E[s_{r_{1}}]E[s_{r_{2}}])t^{T}Wt.
\end{multline*}

\end_inset

Most of the terms cancel, leaving only 
\begin_inset Formula 
\[
p_{wc}(r_{1},r_{2})=t^{T}Wt.
\]

\end_inset

To verify these formulas, simply replace all instances of 
\begin_inset Formula $q_{r}$
\end_inset

 with 
\begin_inset Formula $t$
\end_inset

 in Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:expression lemma"
plural "false"
caps "false"
noprefix "false"

\end_inset

, parts (i) and (ii).
 Since the marginal distribution for every judge is the same under the assumptio
n that 
\begin_inset Formula $q(x)=t(x)$
\end_inset

, it follows that 
\begin_inset Formula $p_{wa}=p_{wa}$
\end_inset

.
 Since the true distribution equals the marginal distribution,
\begin_inset Formula 
\[
t^{T}Wt=p^{T}Wp=(R^{-1}\sum_{r}p_{r})^{T}W(R^{-1}\sum_{r}p_{r})=R^{-2}\sum_{r_{1},r_{2}}p_{r_{1}}^{T}Wp_{r_{2}},
\]

\end_inset

and by part (iii) of Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:expression lemma"
plural "false"
caps "false"
noprefix "false"

\end_inset

, 
\begin_inset Formula $p_{wf}=R^{-2}\sum_{r_{1},r_{2}}p_{r_{1}}^{T}Wp_{r_{2}}$
\end_inset

, Take the mean over all combinations of judges and reorder to arrive at
\begin_inset Formula 
\[
\nu=\frac{p_{wa}-p_{wc}}{1-t^{T}Wt}=\frac{p_{wa}-p_{wc}}{1-p_{wc}}=\frac{p_{wa}-p_{wf}}{1-p_{wf}}=\frac{p_{wa}-p_{wf}}{1-p_{wc}}.
\]

\end_inset


\end_layout

\begin_layout Proof

\series bold
(ii).

\series default
 Assume that all guessing distributions are uniform.
 Then if 
\begin_inset Formula $q_{r}=C^{-1}\mathbf{1}$
\end_inset

, which implies that 
\begin_inset Formula $q_{r}^{T}p=C^{-1}$
\end_inset

 for any probability mass function 
\begin_inset Formula $p$
\end_inset

.
 (This happens since 
\begin_inset Formula $p$
\end_inset

 sums to 
\begin_inset Formula $1$
\end_inset

.) It follows that 
\begin_inset Formula $q_{r_{2}}^{T}t=q_{r_{1}}^{T}q_{r_{2}}=C^{-1}$
\end_inset

 for all 
\begin_inset Formula $r_{1},r_{2}$
\end_inset

.
 Using expression (i) of the Lemma and 
\begin_inset Formula $W=I$
\end_inset

, we find that
\begin_inset Formula 
\begin{multline*}
p_{a}(r_{1},r_{2})=E[s_{r_{1}}s_{r_{2}}]+(E[s_{r_{1}}]-E[s_{r_{1}}s_{r_{2}}])C^{-1}+(E[s_{r_{2}}]-E[s_{r_{1}}s_{r_{2}}])C^{-1}\\
+(1-E[s_{r_{1}}]-E[s_{r_{2}}]+E[s_{r_{1}}s_{r_{2}}])C^{-1}.
\end{multline*}

\end_inset

Canceling terms, we find that 
\begin_inset Formula $p_{a}(r_{1},r_{2})=E[s_{r_{1}}s_{r_{2}}](1-C^{-1})+C^{-1}$
\end_inset

.
 It follows that 
\begin_inset Formula $\nu=\frac{p_{a}-C^{-1}}{1-C^{-1}}$
\end_inset

.
\end_layout

\begin_layout Proof

\series bold
(iii).

\series default
 Suppose that 
\begin_inset Formula $E[s_{r_{1}}s_{r_{2}}]=E[s_{r_{1}}]E[s_{r_{2}}]$
\end_inset

 for all 
\begin_inset Formula $r_{1},r_{2}$
\end_inset

.
 Now subtract 
\begin_inset Formula $p_{wc}(r_{1},r_{2})$
\end_inset

 from 
\begin_inset Formula $p_{wa}(r_{1},r_{2})$
\end_inset

, using Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:expression lemma"
plural "false"
caps "false"
noprefix "false"

\end_inset

, parts (i) and (ii).
 Most of the terms cancel, leaving us with
\begin_inset Formula 
\[
p_{wa}(r_{1},r_{2})-p_{wc}(r_{1},r_{2})=E[s_{r_{1}}s_{r_{2}}](1-t^{T}Wt).
\]

\end_inset

Take the mean over all combinations of judges and reorder to arrive at
\begin_inset Formula 
\[
\nu=\frac{p_{wa}-p_{wc}}{1-t^{T}Wt}.
\]

\end_inset

If the true distribution equals the marginal distribution, then 
\begin_inset Formula $p_{wf}=p^{T}Wp=t^{T}Wt$
\end_inset

, as explained in (i), hence 
\begin_inset Formula $\nu=\frac{p_{wa}-p_{wc}}{1-p_{wf}}$
\end_inset

, as claimed.
 On the other hand, if the true distribution is uniform, 
\begin_inset Formula $t=C^{-1}\mathbf{1}$
\end_inset

, hence 
\begin_inset Formula $\nu=\frac{p_{wa}-p_{wc}}{1-\mathbf{1}^{T}W\mathbf{1}/C^{-2}}$
\end_inset

.
\end_layout

