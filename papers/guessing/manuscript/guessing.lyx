\begin_layout Standard
First, let us recall the multidimensional delta method.
 Let 
\begin_inset Formula $f:\mathbb{R}^{k}\to\mathbb{R}$
\end_inset

 be continuously differentiable at 
\begin_inset Formula $\theta$
\end_inset

 and suppose that 
\begin_inset Formula $\sqrt{n}(\hat{\theta}-\theta)\stackrel{d}{\to}N(0,\Sigma)$
\end_inset

.
 Then 
\begin_inset Formula 
\begin{equation}
\sqrt{n}[f(\hat{\theta})-f(\theta)]\stackrel{d}{\to}N(0,\nabla f(\theta)^{T}\Sigma\nabla f(\theta))\label{eq:delta method}
\end{equation}

\end_inset

In the case of the Cohen–Fleiss coefficient, 
\begin_inset Formula $\theta=(p_{wa},p_{wc},p_{wf})$
\end_inset

 and 
\begin_inset Formula $f(\theta)=\frac{p_{wa}-p_{wc}}{1-p_{wf}}$
\end_inset

.
 Then
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\nabla f=\frac{1}{1-p_{wf}}\left(1,-1,\nu_{CBP}\right).
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
(p_{wa},p_{wc},p_{wf})
\]

\end_inset

Thus the variance is 
\begin_inset Formula 
\begin{eqnarray*}
(1-p_{wf})^{2}\nabla f(\theta)^{T}\Sigma\nabla f(\theta) & = & \left(1,-1,\nu_{CBP}\right)^{T}\Sigma\left(1,-1,\nu_{CBP}\right),\\
 & = & p_{wa}\sigma_{wa}^{2}+p_{wc}^{2}\sigma_{wc}^{2}+p_{wf}^{2}\sigma_{wf}^{2}+2\sigma_{wf}^{2}\sigma_{wc}^{2}.
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Subsection*
Proof that Aickin's model is a guessing model
\begin_inset CommandInset label
LatexCommand label
name "subsec:Proof-that-Aickin's"

\end_inset


\end_layout

\begin_layout Lemma
Let the number of judges be 
\begin_inset Formula $2$
\end_inset

 and 
\begin_inset Formula $s\sim\text{Bernoulli}(\alpha)$
\end_inset

 be the same for both judges.
 Then the guessing model has unconditional distribution
\begin_inset Formula 
\begin{equation}
p(x_{1},x_{2})=\alpha1[x_{1}=x_{2}]t(x_{1})+(1-\alpha)q_{1}(x_{1})q_{2}(x_{2}).\label{eq:generalized aicken model}
\end{equation}

\end_inset


\end_layout

\begin_layout Proof
Expanding the guessing model 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:full guessing model"
plural "false"
caps "false"
noprefix "false"

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
p(x_{1},x_{2}\mid s,x^{\star}) & = & s^{2}1[x_{1}=x^{\star}]1[x_{2}=x^{\star}]\\
 & = & +s(1-s)1[x_{1}=x^{\star}]q_{2}(x_{2})\\
 &  & +s(1-s)1[x_{2}=x^{\star}]q_{1}(x_{1})\\
 &  & +(1-s)(1-s)q_{1}(x_{1})q_{2}(x_{2})
\end{eqnarray*}

\end_inset

Since 
\begin_inset Formula $s\sim\text{Bernoulli}(\alpha)$
\end_inset

, we have that 
\begin_inset Formula $Es^{2}=\alpha$
\end_inset

, 
\begin_inset Formula $E(s(1-s))=0$
\end_inset

 and 
\begin_inset Formula $E(1-s)(1-s)=1-\alpha$
\end_inset

.
 It follows that
\begin_inset Formula 
\[
p(x_{1},x_{2}\mid x^{\star})=\alpha1[x_{1}=x^{\star}]1[x_{2}=x^{\star}]+(1-\alpha)q_{1}(x_{1})q_{2}(x_{2}).
\]

\end_inset

Summing over 
\begin_inset Formula $x^{\star}$
\end_inset

 yields 
\begin_inset Formula $p(x_{1},x_{2})=\alpha1[x_{1}=x_{2}]t(x_{1})+(1-\alpha)q_{1}(x_{1})q_{2}(x_{2})$
\end_inset

.
\end_layout

