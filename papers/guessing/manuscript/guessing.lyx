\begin_layout Theorem
\begin_inset Argument 1
status open

\begin_layout Plain Layout
Knowledge Coefficient Theorem
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "thm:main theorem"

\end_inset

Let 
\begin_inset Formula $w$
\end_inset

 be any agreement weighting function and 
\begin_inset Formula $W$
\end_inset

 its associated agreement weighting matrix.
 Then the following holds:
\end_layout

\begin_deeper
\begin_layout Enumerate
Assume all guessing distributions are equal, i.e, 
\begin_inset Formula $q_{r}(x)=q(x)$
\end_inset

.
 Then the following are equivalent:
\begin_inset Formula 
\[
q(x)=t(x),\quad p(x)=t(x),\quad q(x)=p(x)
\]

\end_inset

Assuming either of these,
\begin_inset Formula $p_{wc}=p_{wf}$
\end_inset

, and the knowledge coefficient equals both the weighted multi-rater Cohen's
 kappa (Conger's kappa) and the weighted Fleiss' kappa
\begin_inset Formula 
\[
\nu=\nu_{C}=\frac{p_{wa}-p_{wc}}{1-p_{wc}};\quad\nu=\nu_{F}=\frac{p_{wa}-p_{wf}}{1-p_{wf}}.
\]

\end_inset


\end_layout

\begin_layout Enumerate
Assume all guessing distributions 
\begin_inset Formula $q_{r}$
\end_inset

 are uniform.
 Then the knowledge coefficient equals the Brennan–Prediger coefficient,
\begin_inset Formula 
\[
\nu=\nu_{BP}=\frac{p_{a}-1/C}{1-1/C},
\]

\end_inset

where 
\begin_inset Formula $p_{a}$
\end_inset

 denotes the weighted agreement with nominal weights.
\end_layout

\begin_layout Enumerate
Assume that the skill-difficulty parameters have pairwise covariance equal
 to zero, i.e., 
\begin_inset Formula $E[s_{r_{1}}s_{r_{2}}]=E[s_{r_{1}}]E[s_{r_{2}}]$
\end_inset

 for all 
\begin_inset Formula $r_{1},r_{2}$
\end_inset

.
 Then the knowledge coefficient equals
\begin_inset Formula 
\[
\nu=\frac{p_{wa}-p{}_{wc}}{1-t^{T}Wt}.
\]

\end_inset

In particular, if 
\begin_inset Formula $t(x)=p(x)$
\end_inset

, it equals the 
\begin_inset Quotes eld
\end_inset

Cohen–Fleiss
\begin_inset Quotes erd
\end_inset

 coefficient
\begin_inset Formula 
\[
\nu=\nu_{CF}=\frac{p_{wa}-p_{wc}}{1-p_{wf}}.
\]

\end_inset

Moreover, if 
\begin_inset Formula $t$
\end_inset

 is uniform, it equals the 
\begin_inset Quotes eld
\end_inset

Cohen–Brennan–Prediger
\begin_inset Quotes erd
\end_inset

 coefficient,
\begin_inset Formula 
\[
\nu=\nu_{CBP}=\frac{p_{wa}-p_{wc}}{1-\boldsymbol{1}^{T}W\boldsymbol{1}/C^{2}}.
\]

\end_inset


\end_layout

\end_deeper
\begin_layout Proof
The knowledge coefficient theorem is proved in the appendix, page 
\begin_inset CommandInset ref
LatexCommand pageref
reference "subsec:proof of knowledge theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
\end_layout

\begin_layout Standard
Every coefficient in the theorem can be estimated by substituting the values
 of 
\begin_inset Formula $p_{wa}$
\end_inset

, 
\begin_inset Formula $p_{wf}$
\end_inset

, and 
\begin_inset Formula $p_{wc}$
\end_inset

 for their sample variants.
 Under any of the equivalent conditions of Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 part (i), we have that that 
\begin_inset Formula $\nu$
\end_inset

 equals 
\begin_inset Formula 
\[
\nu_{F}=\frac{p_{wa}-p_{wf}}{1-p_{wf}},\quad\nu_{C}=\frac{p_{wa}-p_{wc}}{1-p_{wc}},\quad\nu_{CF}=\frac{p_{wa}-p_{wc}}{1-p_{wf}}.
\]

\end_inset

The coefficient 
\begin_inset Formula $\nu_{F}=\frac{p_{wa}-p_{wf}}{1-p_{wf}}$
\end_inset

 is a weighted Fleiss' kappa.
 This coefficient is strongly related to the weighted Krippendorff's alpha,
 which we denote by 
\begin_inset Formula $\hat{\alpha}$
\end_inset

.
 Indeed, it is easy to see that 
\begin_inset Formula $\hat{\alpha}$
\end_inset

 is a linear transformation of 
\begin_inset Formula $\hat{\nu}_{F}$
\end_inset

,
\begin_inset Formula 
\begin{equation}
\hat{\alpha}=\hat{\nu}_{F}+\frac{1}{N}(1-\hat{\nu}_{F}),\label{eq:krippendorffs alpha}
\end{equation}

\end_inset

where 
\begin_inset Formula $N$
\end_inset

 is the total number of ratings made 
\begin_inset CommandInset citation
LatexCommand citep
before "see the appendix of"
key "Anon2022-ep"
literal "false"

\end_inset

 and 
\begin_inset Formula $\hat{\nu}_{F}$
\end_inset

, the sample weighted Fleiss kappa.
 Thus 
\begin_inset Formula $\hat{\alpha}$
\end_inset

 is a consistent estimator of 
\begin_inset Formula $\nu_{F}$
\end_inset

.
 
\end_layout

\begin_layout Standard
On the other hand, 
\begin_inset Formula $\nu_{C}$
\end_inset

 is a weighted multi-rater Cohen's kappa of the form discussed by 
\begin_inset CommandInset citation
LatexCommand citet
key "Berry1988-nc"
literal "false"

\end_inset

 and 
\begin_inset CommandInset citation
LatexCommand citet
key "Janson2001-pk"
literal "false"

\end_inset

; it can also be regarded as a weighted Conger's kappa 
\begin_inset CommandInset citation
LatexCommand citep
key "Conger1980-yx"
literal "false"

\end_inset

.
 I have not seen anything like 
\begin_inset Formula $\nu_{CF}$
\end_inset

, a curious combination of Cohen's kappa and Fleiss' kappa, probably because
 it is not a classical chance-corrected chance measure of agreement, as
 its numerator chance agreement 
\begin_inset Formula $p_{wc}$
\end_inset

 is distinct from the denominator chance agreement 
\begin_inset Formula $p_{wf}$
\end_inset

.
 The required condition for the Cohen–Fleiss coefficient, 
\begin_inset Formula $p(x)=t(x)$
\end_inset

, holds if and only if
\begin_inset Formula 
\[
R^{-1}\sum_{r=1}^{R}\left[(1-s_{r})q_{r}(x)+s_{r}t(x)\right]=t(x)\Longleftrightarrow\sum_{r=1}^{R}(1-s_{r})q_{r}(x)=t(x)\sum_{r=1}^{R}(1-s_{r}),\quad\text{for all }r.
\]

\end_inset

which hols trivially if 
\begin_inset Formula $q_{r}(x)=t(x)$
\end_inset

 for all 
\begin_inset Formula $r$
\end_inset

.
 Hence the Cohen–Fleiss coefficient is consistent for the population knowledge
 coefficient under strictly more situations than weighted Fleiss' kappa
 and weighted multi-rater Cohen's kappa, and may be preferred to them by
 a researcher who buys the rationale behind the guessing model.
 
\end_layout

\begin_layout Standard
The Cohen-Brennan–Prediger coefficient will be equal to the knowledge coefficien
t if the true distribution equals the uniform distribution and the skill-difficu
lty parameters have pairwise covariances equal to zero.
 This scenario may be uncommon, but can happen if the designer of the agreement
 study has complete control over the true ratings.
 
\end_layout

\begin_layout Standard
Part (ii) of Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 concerns the case when a judge who does not know the correct classification
 of an item guesses uniformly at random, so that 
\begin_inset Formula $q_{r}(x)=C^{-1}$
\end_inset

 for all judges 
\begin_inset Formula $r$
\end_inset

.
 This assumption is used by e.g.
 
\begin_inset CommandInset citation
LatexCommand citet
key "Brennan1981-kf"
literal "false"

\end_inset

, 
\begin_inset CommandInset citation
LatexCommand citet
key "Maxwell1977-lf"
literal "false"

\end_inset

, 
\begin_inset CommandInset citation
LatexCommand citet
key "Gwet2008-qk"
literal "false"

\end_inset

 and 
\begin_inset CommandInset citation
LatexCommand citet
key "Perreault1989-mg"
literal "false"

\end_inset

.
 
\end_layout

\begin_layout Example
\begin_inset CommandInset label
LatexCommand label
name "exa:Zapf exampe"

\end_inset

 
\begin_inset CommandInset citation
LatexCommand citet
key "Zapf2016-eu"
literal "false"

\end_inset

 did a case study on histopathological assessment of breast cancer.
 The number of judges was 
\begin_inset Formula $R=4$
\end_inset

, the number breast cancer biopsies rated was 
\begin_inset Formula $n=50,$
\end_inset

and the number of categories 
\begin_inset Formula $C=5$
\end_inset

.
 The estimated coefficients are
\begin_inset Formula 
\[
\hat{\nu}_{CF}=0.574,\quad\hat{\nu}_{F}=0.562,\quad\hat{\nu}_{C}=0.567,\quad\hat{\nu}_{BP}=0.604,\quad\hat{\nu}_{CBP}=0.519.
\]

\end_inset

In this case, the coefficients are quite close, suggesting that the guessing
 distributions are close to the marginal distribution and that the marginal
 distribution is close to the uniform distribution.
 The observed marginal distribution in this data set 
\begin_inset Formula $0.255,0.025,0.12,0.21,0.39$
\end_inset

.
 This appears to be quite far away from the uniform distribution, which
 raises the question of how sensitive the Brennan–Prediger coefficient is
 to the uniformity assumption.
\end_layout

\begin_layout Section
Sensitivity and performance
\end_layout

\begin_layout Standard
Recall the assumptions on the coefficients of Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset


\end_layout

\begin_layout Itemize

\series bold
Brennan–Prediger
\series default
: All guessing distributions are equal to the uniform distribution.
\end_layout

\begin_layout Itemize

\series bold
Cohen's kappa, Fleiss' kappa
\series default
: All guessing distributions are equal, the true distribution equals the
 marginal distribution.
\end_layout

\begin_layout Itemize

\series bold
Cohen–Fleiss
\series default
: The true distribution equals the marginal guessing distribution, 
\begin_inset Formula $E[s_{r_{1}}s_{r_{2}}]=E[s_{r_{1}}]E[s_{r_{2}}]$
\end_inset

 for all 
\begin_inset Formula $r_{1},r_{2}$
\end_inset

.
\end_layout

\begin_layout Itemize

\series bold
Cohen–Brennan–Prediger
\series default
: The true distribution is uniform, 
\begin_inset Formula $E[s_{r_{1}}s_{r_{2}}]=E[s_{r_{1}}]E[s_{r_{2}}]$
\end_inset

 for all 
\begin_inset Formula $r_{1},r_{2}$
\end_inset

.
\end_layout

\begin_layout Standard
These assumptions are quite stringent, and will realistically never hold
 exactly.
 In this section, we do two sensitivity–performance studies to check how
 well the coefficients perform when the assumptions are broken.
 Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 contains two classes of coefficients.
 The first class, containing the Brennan–Prediger coefficient in addition
 to Cohen's and Fleiss' kappa, requires at minimum that all guessing distributio
ns are equal.
 The second class, containing the Cohen–Fleiss and Cohen–Brennan–Prediger
 coefficient, requires that all pairs of skill-difficulty parameters have
 zero covariance.
 We will do two studies, one where 
\begin_inset Formula $s_{r_{1}}$
\end_inset

 and 
\begin_inset Formula $s_{r_{2}}$
\end_inset

 have zero covariance and one where 
\begin_inset Formula $s_{r_{1}}$
\end_inset

 and 
\begin_inset Formula $s_{r_{2}}$
\end_inset

 are correlated.
 We restrict our study the the case of nominal weights.
 
\end_layout

\begin_layout Subsection
When 
\begin_inset Formula $E[s_{r_{1}}s_{r_{2}}]=E[s_{r_{1}}]E[s_{r_{2}}]$
\end_inset

 
\begin_inset CommandInset label
LatexCommand label
name "subsec:sensitivity independence"

\end_inset


\end_layout

\begin_layout Standard
We will use the a special case of the guessing model we call the 
\emph on
judge skill model
\emph default
.
 In this model the skill-difficulty parameter 
\begin_inset Formula $s$
\end_inset

 is deterministic.
 This is a generalization of the models used by e.g.
 
\begin_inset CommandInset citation
LatexCommand citet
key "Perreault1989-mg"
literal "false"

\end_inset

 and 
\begin_inset CommandInset citation
LatexCommand citet
key "Van_Oest2019-pm"
literal "false"

\end_inset

 to allow for judges with different skill levels.
 Since 
\begin_inset Formula $s$
\end_inset

 is deterministic, 
\begin_inset Formula $E[s_{r_{1}}s_{r_{2}}]=E[s_{r_{1}}]E[s_{r_{2}}]$
\end_inset

 and the main condition of Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 part (iii) is satisfied.
 Under the judge skill model, it is fairly easy to calculate the theoretical
 values of the five coefficients in Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:main theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 To calculate 
\begin_inset Formula $p_{wa}$
\end_inset

, we use representation (i) of Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:expression lemma"
plural "false"
caps "false"
noprefix "false"

\end_inset

 (p.
 
\begin_inset CommandInset ref
LatexCommand pageref
reference "lem:expression lemma"
plural "false"
caps "false"
noprefix "false"

\end_inset

), in the appendix.
 Since 
\begin_inset Formula $p_{wf}=p^{T}Wp$
\end_inset

, where 
\begin_inset Formula $p$
\end_inset

 is the marginal distribution, and 
\begin_inset Formula $p_{wc}=\binom{R}{2}^{-1}\sum_{r_{1}>r_{2}}p_{r_{1}}^{T}Wp_{r_{2}}$
\end_inset

, the values of 
\begin_inset Formula $p_{wf}$
\end_inset

 and 
\begin_inset Formula $p_{wc}$
\end_inset

 are easily calculated.
\end_layout

\begin_layout Standard
The parameters 
\begin_inset Formula $R$
\end_inset

, 
\begin_inset Formula $C$
\end_inset

 and 
\begin_inset Formula $s$
\end_inset

 are sampled as follows:
\end_layout

\begin_layout Enumerate
The number of judges (
\begin_inset Formula $R$
\end_inset

) is sampled uniformly from 
\begin_inset Formula $[2,20]$
\end_inset

.
 
\end_layout

\begin_layout Enumerate
The number of categories (
\begin_inset Formula $C$
\end_inset

) is sampled uniformly from 
\begin_inset Formula $[2,10]$
\end_inset

.
\end_layout

\begin_layout Enumerate
The 
\begin_inset Formula $R$
\end_inset

 skill–difficulty parameters 
\begin_inset Formula $s_{1},...,s_{R}$
\end_inset

 are drawn independently from a beta distribution with parameters 
\begin_inset Formula $7$
\end_inset

 and 
\begin_inset Formula $1.5$
\end_inset

.
 This is a slightly dispersed, asymmetric distribution with a mean of 
\begin_inset Formula $0.82$
\end_inset

.
 
\end_layout

\begin_layout Standard
We study what happens when the true distribution deviates from the uniform
 (an assumption for 
\begin_inset Formula $\nu_{CBP}$
\end_inset

) and / or the guessing distribution deviates from the uniform distribution
 (an assumption for 
\begin_inset Formula $\nu_{BP}$
\end_inset

).
 The numbers are the simulated mean absolute deviations from the true knowledge
 coefficient 
\begin_inset Formula $E|\nu-\nu_{x}|$
\end_inset

, where 
\begin_inset Formula $x$
\end_inset

 is one of 
\begin_inset Formula $F,C,BP,CF,$
\end_inset

or 
\begin_inset Formula $CBP$
\end_inset

.
 The smallest numbers by orders of magnitude on each row is in bold.
\end_layout

\begin_layout Subsubsection
True distribution centered on the uniform distribution
\begin_inset CommandInset label
LatexCommand label
name "subsec:True-distribution-centered-uniform"

\end_inset


\end_layout

\begin_layout Standard
If the variability of the true distribution is 
\begin_inset Quotes eld
\end_inset

None
\begin_inset Quotes erd
\end_inset

, it equals the uniform distribution.
 If the variability is 
\begin_inset Quotes eld
\end_inset

Low
\begin_inset Quotes erd
\end_inset

, it is sampled from a symmetric Dirichlet distribution 
\begin_inset CommandInset citation
LatexCommand citep
after "Chapter 49"
key "Johnson1994-ag"
literal "false"

\end_inset

 with concentration parameter 
\begin_inset Formula $\alpha=10$
\end_inset

; if variability is 
\begin_inset Quotes eld
\end_inset

High
\begin_inset Quotes erd
\end_inset

, 
\begin_inset Formula $\alpha=0.5$
\end_inset

.
 Likewise, for the guessing distributions, if the variability is 
\begin_inset Quotes eld
\end_inset

None
\begin_inset Quotes erd
\end_inset

, all guessing distributions are equal to the uniform distribution.
 If the variability is 
\begin_inset Quotes eld
\end_inset

Low
\begin_inset Quotes erd
\end_inset

, the guessing distributions are sampled from a symmetric Dirichlet distribution
 with concentration parameter 
\begin_inset Formula $\alpha=10$
\end_inset

.
 Finally, if the variability is 
\begin_inset Quotes eld
\end_inset

High
\begin_inset Quotes erd
\end_inset

, they are sampled from a symmetric Dirichlet distribution with 
\begin_inset Formula $\alpha=0.5$
\end_inset

.
\end_layout

