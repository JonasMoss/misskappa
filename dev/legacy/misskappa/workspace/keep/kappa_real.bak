// [[Rcpp::depends(RcppArmadillo)]]
#include <RcppArmadillo.h>
#include <set>
#include <unordered_map>

constexpr int NA_INT = -2147483648;

inline double loss(int a, int b) {
  return a == b ? 0.0 : 1.0;
}

// [[Rcpp::export]]
Rcpp::List calculate_kappas_cpp(const arma::imat& ratings, bool use_ipw = true) {

  // 1. Setup
  const int n = ratings.n_rows;
  const int R = ratings.n_cols;
  if (R < 2) Rcpp::stop("ratings matrix must have at least 2 columns (raters).");

  const arma::umat M = (ratings != NA_INT); // Presence matrix (1 if not NA)

  // Get number of categories C for Brennan-Prediger
  std::set<int> cat_set;
  for (int i = 0; i < n; ++i) {
    for (int j = 0; j < R; ++j) {
      if (M(i, j)) {
        cat_set.insert(ratings(i, j));
      }
    }
  }
  const int C = cat_set.size();
  if (C == 0) Rcpp::stop("All ratings are missing.");

  // 2. Calculate Weights (pi)
  arma::vec pi_j(R);
  arma::mat pi_jk(R, R);
  if (use_ipw) {
    pi_j = arma::conv_to<arma::vec>::from(arma::sum(M, 0)) / n;
    pi_jk = arma::conv_to<arma::mat>::from(M.t() * M) / n;
    if (arma::any(pi_j == 0)) {
      Rcpp::stop("One or more raters has no ratings. Cannot use IPW.");
    }
  } else {
    pi_j.ones();
    pi_jk.ones();
  }
  arma::vec pi_j_inv = 1.0 / pi_j;
  arma::mat pi_jk_inv(R, R, arma::fill::zeros);
  for(int j=0; j < R; ++j) {
    for(int k=0; k < R; ++k) {
      if (j != k && pi_jk(j, k) > 0) {
        pi_jk_inv(j, k) = 1.0 / pi_jk(j, k);
      }
    }
  }


  // 3. Calculate Point Estimates of Psi Components
  double psi_dN_sum = 0, psi_dD_sum = 0, psi_CN_sum = 0,
    psi_CD_sum = 0, psi_FN_sum = 0, psi_FD_sum = 0;

  for (int i = 0; i < n; ++i) {
    // d_hat components (U-statistic style)
    for (int j = 0; j < R - 1; ++j) {
      for (int k = j + 1; k < R; ++k) {
        if (M(i, j) && M(i, k)) {
          psi_dN_sum += loss(ratings(i, j), ratings(i, k)) * pi_jk_inv(j, k);
          psi_dD_sum += pi_jk_inv(j, k);
        }
      }
    }
    // d_C and d_F components (V-statistic style)
    for (int ip = 0; ip < n; ++ip) {
      // Conger
      for (int j = 0; j < R - 1; ++j) {
        for (int k = j + 1; k < R; ++k) {
          if (M(i, j) && M(ip, k)) {
            double w = pi_j_inv(j) * pi_j_inv(k);
            psi_CN_sum += loss(ratings(i, j), ratings(ip, k)) * w;
            psi_CD_sum += w;
          }
        }
      }
      // Fleiss
      for (int j = 0; j < R; ++j) {
        for (int k = 0; k < R; ++k) {
          if (M(i, j) && M(ip, k)) {
            double w = pi_j_inv(j) * pi_j_inv(k);
            psi_FN_sum += loss(ratings(i, j), ratings(ip, k)) * w;
            psi_FD_sum += w;
          }
        }
      }
    }
  }

  const double psi_dN_hat = psi_dN_sum / n;
  const double psi_dD_hat = psi_dD_sum / n;
  const double psi_CN_hat = psi_CN_sum / (n * n);
  const double psi_CD_hat = psi_CD_sum / (n * n);
  const double psi_FN_hat = psi_FN_sum / (n * n);
  const double psi_FD_hat = psi_FD_sum / (n * n);

  // Calculate Disagreement and Kappa Estimates
  const double d_hat = (psi_dD_hat > 0) ? psi_dN_hat / psi_dD_hat : 0.0;
  const double d_C_hat = (psi_CD_hat > 0) ? psi_CN_hat / psi_CD_hat : 0.0;
  const double d_F_hat = (psi_FD_hat > 0) ? psi_FN_hat / psi_FD_hat : 0.0;
  const double d_BP = (double)(C - 1) / C;

  arma::vec kappa_estimates(3);
  kappa_estimates(0) = (d_C_hat > 0) ? 1.0 - d_hat / d_C_hat : 0.0; // Conger
  kappa_estimates(1) = (d_F_hat > 0) ? 1.0 - d_hat / d_F_hat : 0.0; // Fleiss
  kappa_estimates(2) = (d_BP > 0) ? 1.0 - d_hat / d_BP : 0.0;       // BP

  // 4. Calculate Influence Functions
  // U-statistic component influences
  arma::vec h_dN(n, arma::fill::zeros), h_dD(n, arma::fill::zeros);
  for (int i = 0; i < n; ++i) {
    for (int j = 0; j < R - 1; ++j) {
      for (int k = j + 1; k < R; ++k) {
        if (M(i, j) && M(i, k)) {
          h_dN(i) += loss(ratings(i, j), ratings(i, k)) * pi_jk_inv(j, k);
          h_dD(i) += pi_jk_inv(j, k);
        }
      }
    }
  }
  arma::vec phi_dN = h_dN - psi_dN_hat;
  arma::vec phi_dD = h_dD - psi_dD_hat;

  // V-statistic component influences (corrected method)
  // Pre-build kernel matrices for efficiency
  arma::mat kernel_CN(n, n), kernel_CD(n, n), kernel_FN(n, n), kernel_FD(n, n);

  for (int i = 0; i < n; ++i) {
    for (int ip = 0; ip < n; ++ip) {
      double h_cn = 0, h_cd = 0, h_fn = 0, h_fd = 0;
      // Conger kernel h(Z_i, Z_ip)
      for (int j = 0; j < R - 1; ++j) {
        for (int k = j + 1; k < R; ++k) {
          if (M(i, j) && M(ip, k)) {
            double w = pi_j_inv(j) * pi_j_inv(k);
            h_cn += loss(ratings(i, j), ratings(ip, k)) * w;
            h_cd += w;
          }
        }
      }
      // Fleiss kernel h(Z_i, Z_ip)
      for (int j = 0; j < R; ++j) {
        for (int k = 0; k < R; ++k) {
          if (M(i, j) && M(ip, k)) {
            double w = pi_j_inv(j) * pi_j_inv(k);
            h_fn += loss(ratings(i, j), ratings(ip, k)) * w;
            h_fd += w;
          }
        }
      }
      kernel_CN(i, ip) = h_cn; kernel_CD(i, ip) = h_cd;
      kernel_FN(i, ip) = h_fn; kernel_FD(i, ip) = h_fd;
    }
  }

  // Projections: g1 (row means) and g2 (col means)
  arma::vec h_CN1 = arma::mean(kernel_CN, 1);
  arma::vec h_CN2 = arma::mean(kernel_CN, 0).t();
  arma::vec h_CD1 = arma::mean(kernel_CD, 1);
  arma::vec h_CD2 = arma::mean(kernel_CD, 0).t();
  arma::vec h_FN1 = arma::mean(kernel_FN, 1);
  arma::vec h_FN2 = arma::mean(kernel_FN, 0).t();
  arma::vec h_FD1 = arma::mean(kernel_FD, 1);
  arma::vec h_FD2 = arma::mean(kernel_FD, 0).t();

  // Influence function = (g1 - theta) + (g2 - theta)
  arma::vec phi_CN = (h_CN1 - psi_CN_hat) + (h_CN2 - psi_CN_hat);
  arma::vec phi_CD = (h_CD1 - psi_CD_hat) + (h_CD2 - psi_CD_hat);
  arma::vec phi_FN = (h_FN1 - psi_FN_hat) + (h_FN2 - psi_FN_hat);
  arma::vec phi_FD = (h_FD1 - psi_FD_hat) + (h_FD2 - psi_FD_hat);

  // Assemble the n x 6 matrix of influence functions
  arma::mat phi_matrix(n, 6);
  phi_matrix.col(0) = phi_dN;
  phi_matrix.col(1) = phi_dD;
  phi_matrix.col(2) = phi_CN;
  phi_matrix.col(3) = phi_CD;
  phi_matrix.col(4) = phi_FN;
  phi_matrix.col(5) = phi_FD;

  // Asymptotic covariance matrix of the 6 Psi components
  arma::mat Gamma_hat = (1.0 / n) * phi_matrix.t() * phi_matrix;

  // 5. Delta Method 1: Asymptotic Covariance of Disagreements (Sigma_hat)
  arma::mat J_d(3, 6, arma::fill::zeros);
  if (psi_dD_hat > 0) {
    J_d(0, 0) = 1.0 / psi_dD_hat;
    J_d(0, 1) = -psi_dN_hat / (psi_dD_hat * psi_dD_hat);
  }
  if (psi_CD_hat > 0) {
    J_d(1, 2) = 1.0 / psi_CD_hat;
    J_d(1, 3) = -psi_CN_hat / (psi_CD_hat * psi_CD_hat);
  }
  if (psi_FD_hat > 0) {
    J_d(2, 4) = 1.0 / psi_FD_hat;
    J_d(2, 5) = -psi_FN_hat / (psi_FD_hat * psi_FD_hat);
  }
  arma::mat Sigma_hat = J_d * Gamma_hat * J_d.t();

  // 6. Delta Method 2: Asymptotic Covariance of Kappas
  arma::mat J_kappa(3, 3, arma::fill::zeros);
  if (d_C_hat > 0) {
    J_kappa(0, 0) = -1.0 / d_C_hat;
    J_kappa(0, 1) = d_hat / (d_C_hat * d_C_hat);
  }
  if (d_F_hat > 0) {
    J_kappa(1, 0) = -1.0 / d_F_hat;
    J_kappa(1, 2) = d_hat / (d_F_hat * d_F_hat);
  }
  if (d_BP > 0) {
    J_kappa(2, 0) = -1.0 / d_BP;
  }
  arma::mat kappa_cov_asymptotic = J_kappa * Sigma_hat * J_kappa.t();
  arma::mat kappa_cov_matrix = kappa_cov_asymptotic / n;

  // 7. Structure and Return Final Output
  arma::vec disagreement_estimates = {d_hat, d_C_hat, d_F_hat};

  Rcpp::CharacterVector kappa_names = {"Kappa_C", "Kappa_F", "Kappa_BP"};
  Rcpp::CharacterVector disagreement_names = {"d", "d_C", "d_F"};

  Rcpp::List kappa_dimnames = Rcpp::List::create(kappa_names, kappa_names);
  Rcpp::List disagreement_dimnames = Rcpp::List::create(disagreement_names, disagreement_names);


  return Rcpp::List::create(
    Rcpp::_["kappa_estimates"] = kappa_estimates,
    Rcpp::_["kappa_cov_matrix"] = kappa_cov_matrix,
    Rcpp::_["disagreement_estimates"] = disagreement_estimates,
    Rcpp::_["disagreement_cov_matrix"] = Sigma_hat / n // Scale to be var of estimator
  );
}
