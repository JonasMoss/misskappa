// misskappa.cpp
// [[Rcpp::depends(RcppArmadillo)]]
#include <RcppArmadillo.h>
#include "misskappa.hpp"

//' @keywords internal
 // [[Rcpp::export]]
 arma::mat generate_loss_matrix_cpp(
     std::string type,
     int c,
     Rcpp::Nullable<Rcpp::NumericVector> values = R_NilValue) {

   std::optional<arma::vec> values_opt;
   bool needs_values = (type != "identity" && type != "unweighted" && type != "ordinal");

   if (needs_values) {
     if (values.isNotNull()) {
       values_opt = Rcpp::as<arma::vec>(values);
     } else {
       values_opt = arma::regspace(1, c);
     }
   }

   misskappa::Result<arma::mat> w_res_result;
   if (type == "identity" || type == "unweighted") {
     w_res_result = misskappa::loss::identity_weights(c);
   } else if (type == "linear") {
     w_res_result = misskappa::loss::linear_weights(c, values_opt.value());
   } else if (type == "quadratic") {
     w_res_result = misskappa::loss::quadratic_weights(c, values_opt.value());
   } else if (type == "ordinal") {
     w_res_result = misskappa::loss::ordinal_weights(c);
   } else if (type == "radical") {
     w_res_result = misskappa::loss::radical_weights(c, values_opt.value());
   } else if (type == "ratio") {
     w_res_result = misskappa::loss::ratio_weights(c, values_opt.value());
   } else if (type == "circular") {
     w_res_result = misskappa::loss::circular_weights(c, values_opt.value());
   } else if (type == "bipolar") {
     w_res_result = misskappa::loss::bipolar_weights(c, values_opt.value());
   } else {
     Rcpp::stop("Unknown weight type: " + type);
   }

   if (!w_res_result.IsOk()) {
     Rcpp::stop(w_res_result.error_message);
   }
   arma::mat w_res = w_res_result.value;

   return arma::ones<arma::mat>(c, c) - w_res;
 }

// Common function to orchestrate analysis for "counts" model
Rcpp::List run_counts_analysis(
    const arma::umat& x, int r,
    std::function<misskappa::Result<misskappa::estimators::Estimator>(const misskappa::EM_Result&, const arma::mat&)> estimator_factory_builder,
    std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values,
    Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options
) {
  int c = x.n_cols;
  arma::mat loss_matrix = generate_loss_matrix_cpp(weight_type, c, values);

  // --- Step 1 & 2: Preprocessing & EM ---
  auto prep_res = misskappa::preprocess_counts(x, r);
  if (!prep_res.IsOk()) Rcpp::stop(prep_res.error_message);
  misskappa::EM_Options em_opts;
  em_opts.tol = Rcpp::as<double>(em_options["tol"]);
  em_opts.max_iter = Rcpp::as<int>(em_options["max_iter"]);
  em_opts.prune_tol = Rcpp::as<double>(em_options["prune_tol"]);
  em_opts.start_alpha = Rcpp::as<double>(em_options["start_alpha"]);
  auto em_res = misskappa::run_em(prep_res.value, em_opts);
  if (!em_res.IsOk()) Rcpp::stop(em_res.error_message);

  // --- Step 3: Point Estimate and Analytical Variance ---
  auto est_factory = estimator_factory_builder(em_res.value, loss_matrix);
  if (!est_factory.IsOk()) Rcpp::stop(est_factory.error_message);
  auto estimate = misskappa::analysis::calculate_estimate(em_res.value, est_factory.value);
  if (!estimate.IsOk()) Rcpp::stop(estimate.error_message);

  // --- Assemble Core Results ---
  Rcpp::List results = Rcpp::List::create(
    Rcpp::Named("estimate") = estimate.value.value,
    Rcpp::Named("variance") = estimate.value.variance,
    Rcpp::Named("se") = std::sqrt(estimate.value.variance),
    Rcpp::Named("em_converged") = em_res.value.converged,
    Rcpp::Named("em_iterations") = em_res.value.iterations
  );

  // --- Step 4: Optional CI and Bootstrap ---
  if (analysis_options.isNotNull()) {
    Rcpp::List analysis_opts_list = Rcpp::as<Rcpp::List>(analysis_options);

    // 4a: Analytical CI
    misskappa::analysis::ci::CI_Options ci_opts;
    ci_opts.conf_level = Rcpp::as<double>(analysis_opts_list["conf_level"]);
    std::string transform_str = Rcpp::as<std::string>(analysis_opts_list["ci_transform"]);
    if(transform_str == "fisher") ci_opts.transform_type = misskappa::analysis::ci::Transform::kFisherZ;
    else if(transform_str == "arcsin") ci_opts.transform_type = misskappa::analysis::ci::Transform::kArcsin;
    else if(transform_str == "log") ci_opts.transform_type = misskappa::analysis::ci::Transform::kLog;
    auto ci_result = misskappa::analysis::ci::calculate_ci(estimate.value, ci_opts);
    if (!ci_result.IsOk()) Rcpp::warning("Could not calculate analytical CI: " + ci_result.error_message);

    results["ci.lower"] = ci_result.IsOk() ? ci_result.value.lower : NA_REAL;
    results["ci.upper"] = ci_result.IsOk() ? ci_result.value.upper : NA_REAL;
    results["conf.level"] = ci_opts.conf_level;
    results["ci.transform"] = transform_str;

    // 4b: Bootstrap
    std::string boot_method = Rcpp::as<std::string>(analysis_opts_list["bootstrap_method"]);
    results["bootstrap_method"] = boot_method;
    if (boot_method != "none") {
      misskappa::analysis::bootstrap::BootstrapOptions boot_opts;
      boot_opts.reps = Rcpp::as<int>(analysis_opts_list["bootstrap_reps"]);
      boot_opts.conf_level = ci_opts.conf_level;
      Rcpp::Nullable<long long> seed_val = analysis_opts_list["seed"];
      if (seed_val.isNotNull()) boot_opts.seed = Rcpp::as<long long>(seed_val);

      if (boot_method == "nonparametric-t" || boot_method == "parametric-t") {
        boot_opts.studentized = true;
      }

      misskappa::Result<misskappa::analysis::bootstrap::BootstrapResult> boot_res;

      if (boot_method == "nonparametric" || boot_method == "nonparametric-t") {
        boot_res = misskappa::analysis::bootstrap::run_nonparametric_bootstrap<arma::umat>(
          x, r, estimator_factory_builder, loss_matrix, estimate.value, em_opts, boot_opts
        );
      } else if (boot_method == "parametric" || boot_method == "parametric-t") {
        boot_res = misskappa::analysis::bootstrap::run_parametric_bootstrap(
          em_res.value, est_factory.value, estimate.value, boot_opts
        );
      } else {
        boot_res.status = misskappa::Status::kError;
        boot_res.error_message = "Bootstrap method '" + boot_method + "' not recognized by C++ backend.";
      }

      if(!boot_res.IsOk()) {
        Rcpp::warning("Bootstrapping failed: " + boot_res.error_message);
      } else {
        results["se.boot"] = boot_res.value.se;
        results["ci.lower.boot"] = boot_res.value.ci_lower;
        results["ci.upper.boot"] = boot_res.value.ci_upper;
      }
    }
  }

  return results;
}

// Common function to orchestrate analysis for "raw" model
Rcpp::List run_raw_analysis(
    const arma::imat& x, int c,
    std::function<misskappa::Result<misskappa::estimators::Estimator>(const misskappa::EM_Result&, const arma::mat&)> estimator_factory_builder,
    std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values,
    Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options
) {
  arma::mat loss_matrix = generate_loss_matrix_cpp(weight_type, c, values);

  // --- Step 1 & 2: Preprocessing & EM ---
  auto prep_res = misskappa::preprocess_raw(x, c);
  if (!prep_res.IsOk()) Rcpp::stop(prep_res.error_message);
  misskappa::EM_Options em_opts;
  em_opts.tol = Rcpp::as<double>(em_options["tol"]);
  em_opts.max_iter = Rcpp::as<int>(em_options["max_iter"]);
  em_opts.prune_tol = Rcpp::as<double>(em_options["prune_tol"]);
  em_opts.start_alpha = Rcpp::as<double>(em_options["start_alpha"]);
  auto em_res = misskappa::run_em(prep_res.value, em_opts);
  if (!em_res.IsOk()) Rcpp::stop(em_res.error_message);

  // --- Step 3: Point Estimate and Analytical Variance ---
  auto est_factory = estimator_factory_builder(em_res.value, loss_matrix);
  if (!est_factory.IsOk()) Rcpp::stop(est_factory.error_message);
  auto estimate = misskappa::analysis::calculate_estimate(em_res.value, est_factory.value);
  if (!estimate.IsOk()) Rcpp::stop(estimate.error_message);

  // --- Assemble Core Results ---
  Rcpp::List results = Rcpp::List::create(
    Rcpp::Named("estimate") = estimate.value.value,
    Rcpp::Named("variance") = estimate.value.variance,
    Rcpp::Named("se") = std::sqrt(estimate.value.variance),
    Rcpp::Named("em_converged") = em_res.value.converged,
    Rcpp::Named("em_iterations") = em_res.value.iterations
  );

  // --- Step 4: Optional CI and Bootstrap ---
  if (analysis_options.isNotNull()) {
    Rcpp::List analysis_opts_list = Rcpp::as<Rcpp::List>(analysis_options);

    // 4a: Analytical CI
    misskappa::analysis::ci::CI_Options ci_opts;
    ci_opts.conf_level = Rcpp::as<double>(analysis_opts_list["conf_level"]);
    std::string transform_str = Rcpp::as<std::string>(analysis_opts_list["ci_transform"]);
    if(transform_str == "fisher") ci_opts.transform_type = misskappa::analysis::ci::Transform::kFisherZ;
    else if(transform_str == "arcsin") ci_opts.transform_type = misskappa::analysis::ci::Transform::kArcsin;
    else if(transform_str == "log") ci_opts.transform_type = misskappa::analysis::ci::Transform::kLog;
    auto ci_result = misskappa::analysis::ci::calculate_ci(estimate.value, ci_opts);
    if (!ci_result.IsOk()) Rcpp::warning("Could not calculate analytical CI: " + ci_result.error_message);

    results["ci.lower"] = ci_result.IsOk() ? ci_result.value.lower : NA_REAL;
    results["ci.upper"] = ci_result.IsOk() ? ci_result.value.upper : NA_REAL;
    results["conf.level"] = ci_opts.conf_level;
    results["ci.transform"] = transform_str;

    // 4b: Bootstrap
    std::string boot_method = Rcpp::as<std::string>(analysis_opts_list["bootstrap_method"]);
    results["bootstrap_method"] = boot_method;
    if (boot_method != "none") {
      misskappa::analysis::bootstrap::BootstrapOptions boot_opts;
      boot_opts.reps = Rcpp::as<int>(analysis_opts_list["bootstrap_reps"]);
      boot_opts.conf_level = ci_opts.conf_level;
      Rcpp::Nullable<long long> seed_val = analysis_opts_list["seed"];
      if (seed_val.isNotNull()) boot_opts.seed = Rcpp::as<long long>(seed_val);

      if (boot_method == "nonparametric-t" || boot_method == "parametric-t") {
        boot_opts.studentized = true;
      }

      misskappa::Result<misskappa::analysis::bootstrap::BootstrapResult> boot_res;

      if (boot_method == "nonparametric" || boot_method == "nonparametric-t") {
        boot_res = misskappa::analysis::bootstrap::run_nonparametric_bootstrap<arma::imat>(
          x, c, estimator_factory_builder, loss_matrix, estimate.value, em_opts, boot_opts
        );
      } else if (boot_method == "parametric" || boot_method == "parametric-t") {
        boot_res = misskappa::analysis::bootstrap::run_parametric_bootstrap(
          em_res.value, est_factory.value, estimate.value, boot_opts
        );
      } else {
        boot_res.status = misskappa::Status::kError;
        boot_res.error_message = "Bootstrap method '" + boot_method + "' not recognized by C++ backend.";
      }

      if(!boot_res.IsOk()) {
        Rcpp::warning("Bootstrapping failed: " + boot_res.error_message);
      } else {
        results["se.boot"] = boot_res.value.se;
        results["ci.lower.boot"] = boot_res.value.ci_lower;
        results["ci.upper.boot"] = boot_res.value.ci_upper;
      }
    }
  }

  return results;
}

//' @export
 // [[Rcpp::export]]
 Rcpp::List fleiss_cpp(const arma::umat& x, int r, std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values, Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options = R_NilValue) {
   return run_counts_analysis(x, r, misskappa::estimators::fleiss_kappa, weight_type, values, em_options, analysis_options);
 }

//' @export
 // [[Rcpp::export]]
 Rcpp::List fleiss_raw_cpp(const arma::imat& x, int c, std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values, Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options = R_NilValue) {
   return run_raw_analysis(x, c, misskappa::estimators::fleiss_kappa, weight_type, values, em_options, analysis_options);
 }

//' @export
 // [[Rcpp::export]]
 Rcpp::List bp_cpp(const arma::umat& x, int r, std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values, Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options = R_NilValue) {
   return run_counts_analysis(x, r, misskappa::estimators::brennan_prediger, weight_type, values, em_options, analysis_options);
 }

//' @export
 // [[Rcpp::export]]
 Rcpp::List bp_raw_cpp(const arma::imat& x, int c, std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values, Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options = R_NilValue) {
   return run_raw_analysis(x, c, misskappa::estimators::brennan_prediger, weight_type, values, em_options, analysis_options);
 }

//' @export
 // [[Rcpp::export]]
 Rcpp::List conger_cpp(const arma::imat& x, int c, std::string weight_type, Rcpp::Nullable<Rcpp::NumericVector> values, Rcpp::List em_options, Rcpp::Nullable<Rcpp::List> analysis_options = R_NilValue) {
   return run_raw_analysis(x, c, misskappa::estimators::conger_kappa, weight_type, values, em_options, analysis_options);
 }
// Custom hasher for std::vector<int> to enable use in unordered_map
struct VectorHasher {
  std::size_t operator()(const std::vector<int>& vec) const {
    std::size_t seed = vec.size();
    for(int i : vec) {
      seed ^= i + 0x9e3779b9 + (seed << 6) + (seed >> 2);
    }
    return seed;
  }
};

//' @keywords internal
// [[Rcpp::export]]
Rcpp::List conger_ac_cpp(
     const arma::imat& x,
     std::string weight_type,
     Rcpp::Nullable<Rcpp::NumericVector> values = R_NilValue) {

   const arma::uword n = x.n_rows;
   const arma::uword r = x.n_cols;

   // --- 1. Identify categories and create mapping ---
   std::set<int> unique_cats_set;
   for (arma::uword i = 0; i < x.n_elem; ++i) {
     if (x(i) != misskappa::kNaInteger) unique_cats_set.insert(x(i));
   }
   if (unique_cats_set.size() <= 1) {
     return Rcpp::List::create(Rcpp::Named("estimate") = NA_REAL, Rcpp::Named("se") = NA_REAL);
   }
   std::vector<int> cat_vec(unique_cats_set.begin(), unique_cats_set.end());
   arma::vec cat_arma_vec(cat_vec.size());
   std::unordered_map<int, int> cat_to_zb_map;
   for (size_t i = 0; i < cat_vec.size(); ++i) {
     cat_to_zb_map[cat_vec[i]] = i;
     cat_arma_vec(i) = cat_vec[i];
   }
   const int q = cat_vec.size();

   // --- 2. Weight Matrix (Agreement) ---
   Rcpp::Nullable<Rcpp::NumericVector> values_for_weights = values;
   if (!values.isNotNull()) values_for_weights = Rcpp::wrap(cat_arma_vec);
   arma::mat loss_mat = generate_loss_matrix_cpp(weight_type, q, values_for_weights);
   arma::mat W = arma::ones<arma::mat>(q, q) - loss_mat;

   // --- 3. Compute Observed Agreement (pa) ---
   double total_agreements = 0;
   double total_pairs = 0;
   arma::vec pa_ivec(n, arma::fill::zeros);
   arma::vec ri_vec(n, arma::fill::zeros);

   for(arma::uword i = 0; i < n; ++i) {
     double subject_agreements = 0;
     double subject_pairs = 0;
     for(arma::uword j1 = 0; j1 < r; ++j1) {
       for(arma::uword j2 = j1 + 1; j2 < r; ++j2) {
         if(x(i, j1) != misskappa::kNaInteger && x(i, j2) != misskappa::kNaInteger) {
           int cat1 = cat_to_zb_map.at(x(i, j1));
           int cat2 = cat_to_zb_map.at(x(i, j2));
           subject_agreements += W(cat1, cat2);
           subject_pairs++;
         }
       }
     }
     if (subject_pairs > 0) {
       pa_ivec(i) = subject_agreements / subject_pairs;
     }
     total_agreements += subject_agreements;
     total_pairs += subject_pairs;
     ri_vec(i) = arma::accu(x.row(i) != misskappa::kNaInteger);
   }
   double pa = (total_pairs > 0) ? total_agreements / total_pairs : 0.0;

   // --- 4. Compute Chance Agreement (pe) ---
   arma::mat classif_mat(r, q, arma::fill::zeros);
   for (arma::uword i = 0; i < n; ++i) {
     for (arma::uword j = 0; j < r; ++j) {
       if (x(i, j) != misskappa::kNaInteger) {
         classif_mat(j, cat_to_zb_map.at(x(i, j)))++;
       }
     }
   }
   arma::vec ng_vec = arma::sum(classif_mat, 1);
   arma::mat pgk_mat = classif_mat.each_col() / ng_vec;
   pgk_mat.replace(arma::datum::nan, 0);

   arma::vec p_mean_k = arma::mean(pgk_mat, 0).t();

   arma::mat s2kl_mat;
   if (r > 1) {
     s2kl_mat = (pgk_mat.t() * pgk_mat - r * p_mean_k * p_mean_k.t()) / (r - 1.0);
   } else {
     s2kl_mat = arma::zeros<arma::mat>(q, q);
   }

   double pe = arma::accu(W % (p_mean_k * p_mean_k.t() - s2kl_mat / r));

   if (std::abs(1.0 - pe) < 1e-12) return Rcpp::List::create(Rcpp::Named("estimate") = 1.0, Rcpp::Named("se") = 0.0);
   double kappa = (pa - pe) / (1.0 - pe);

   // --- 5. Variance Calculation (irrCAC Jackknife Method) ---
   arma::mat bkl_mat = 0.5 * (W + W.t());
   arma::mat lamda_ig_mat(n, r, arma::fill::zeros);
   arma::mat epsi_ig_mat(n, r, arma::fill::zeros);
   epsi_ig_mat.elem(arma::find(x != misskappa::kNaInteger)).ones();

   for (int k = 0; k < q; ++k) {
     arma::mat lamda_ig_kmat(n, r, arma::fill::zeros);
     for (int l = 0; l < q; ++l) {
       arma::mat delta_ig_mat(n, r, arma::fill::zeros);
       delta_ig_mat.elem(arma::find(x == cat_vec[l])).ones();

       arma::mat term_in_paren = delta_ig_mat - (epsi_ig_mat - arma::ones<arma::mat>(n, 1) * (ng_vec / n).t()) % (arma::ones<arma::mat>(n, 1) * pgk_mat.col(l).t());
       lamda_ig_kmat += bkl_mat(k, l) * term_in_paren;
     }

     arma::vec n_over_ng = n / ng_vec;
     n_over_ng.elem(arma::find_nonfinite(n_over_ng)).zeros();
     lamda_ig_kmat.each_row() %= n_over_ng.t();

     arma::mat term2 = (r * p_mean_k(k)) * arma::ones<arma::mat>(n, r) - arma::ones<arma::mat>(n, 1) * pgk_mat.col(k).t();
     lamda_ig_mat += lamda_ig_kmat % term2;
   }

   arma::vec pe_ivec = arma::sum(lamda_ig_mat, 1) / (r * (r - 1.0));

   double n2more = arma::accu(ri_vec >= 2.0);
   arma::vec pe_r2 = pe * arma::conv_to<arma::vec>::from(ri_vec >= 2.0);
   arma::vec conger_ivec = (n / n2more) * (pa_ivec - pe_r2) / (1.0 - pe);
   arma::vec conger_ivec_x = conger_ivec - 2.0 * (1.0 - kappa) * (pe_ivec - pe) / (1.0 - pe);

   double var_conger = arma::accu(arma::pow(conger_ivec_x - kappa, 2)) / (n * n);

   return Rcpp::List::create(Rcpp::Named("estimate") = kappa, Rcpp::Named("se") = std::sqrt(var_conger));
 }
