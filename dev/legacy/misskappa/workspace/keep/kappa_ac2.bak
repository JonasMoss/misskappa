#include <RcppArmadillo.h>
#include <unordered_map>

// [[Rcpp::depends(RcppArmadillo)]]

// Sentinel for R's NA_INTEGER
constexpr int kNaInteger = -2147483648;

// Custom hash function for arma::ivec to enable its use in unordered_map
struct ArmaIVecHash {
  std::size_t operator()(const arma::ivec& v) const {
    std::size_t seed = v.n_elem;
    for(arma::uword i = 0; i < v.n_elem; ++i) {
      seed ^= v(i) + 0x9e3779b9 + (seed << 6) + (seed >> 2);
    }
    return seed;
  }
};

// Custom equality predicate for arma::ivec
struct ArmaIVecEqual {
  bool operator()(const arma::ivec& a, const arma::ivec& b) const {
    if (a.n_elem != b.n_elem) {
      return false;
    }
    return arma::all(a == b);
  }
};

// [[Rcpp::export]]
Rcpp::List conger_ac_cpp2(const arma::imat& x, int disagreement_type, double conf_level) {
  int n = x.n_rows;
  int R = x.n_cols;

  if (R < 2) {
    Rcpp::stop("Data must have at least 2 raters.");
  }

  // 1. Binning with hashing and a custom equality predicate
  std::unordered_map<arma::ivec, int, ArmaIVecHash, ArmaIVecEqual> unique_row_map;
  arma::uvec inverse_indices(n);
  std::vector<arma::ivec> unique_rows_vec;
  arma::uvec counts;
  int u_idx = 0;

  for (int i = 0; i < n; ++i) {
    arma::ivec current_row = x.row(i).t();
    auto it = unique_row_map.find(current_row);
    if (it == unique_row_map.end()) {
      unique_row_map[current_row] = u_idx;
      unique_rows_vec.push_back(current_row);
      inverse_indices(i) = u_idx;
      counts.resize(u_idx + 1);
      counts(u_idx) = 1;
      u_idx++;
    } else {
      inverse_indices(i) = it->second;
      counts(it->second)++;
    }
  }

  int U = unique_rows_vec.size();
  arma::imat x_unique(U, R);
  for(int i=0; i < U; ++i) {
    x_unique.row(i) = unique_rows_vec[i].t();
  }

  // 2. Compute components on unique rows
  auto get_disagreement = [&](int v1, int v2) {
    switch (disagreement_type) {
    case 1: return (v1 == v2) ? 0.0 : 1.0;
    case 2: return static_cast<double>(std::abs(v1 - v2));
    case 3: return std::pow(static_cast<double>(v1 - v2), 2.0);
    default: Rcpp::stop("Unknown disagreement type.");
    }
    return 0.0;
  };

  arma::vec A_unique(U, arma::fill::zeros);
  arma::vec B_unique(U, arma::fill::zeros);
  arma::mat hC_unique(U, U, arma::fill::zeros);
  arma::mat hD_unique(U, U, arma::fill::zeros);
  arma::umat M_unique = (x_unique != kNaInteger);

  for (int u = 0; u < U; ++u) {
    for (int j = 0; j < R - 1; ++j) {
      for (int k = j + 1; k < R; ++k) {
        if (M_unique(u, j) && M_unique(u, k)) {
          A_unique(u) += get_disagreement(x_unique(u, j), x_unique(u, k));
          B_unique(u) += 1.0;
        }
      }
    }
  }

  for (int u = 0; u < U; ++u) {
    for (int v = 0; v < U; ++v) {
      for (int j = 0; j < R - 1; ++j) {
        for (int k = j + 1; k < R; ++k) {
          if (M_unique(u, j) && M_unique(v, k)) {
            hC_unique(u, v) += get_disagreement(x_unique(u, j), x_unique(v, k));
            hD_unique(u, v) += 1.0;
          }
        }
      }
    }
  }

  // 3. Calculate point estimates using binned components
  double A_bar = arma::dot(counts, A_unique) / n;
  double B_bar = arma::dot(counts, B_unique) / n;
  double d_hat = (B_bar > 0) ? A_bar / B_bar : 0.0;

  double V_c_hat = arma::as_scalar(counts.t() * hC_unique * counts) / (double(n) * n);
  double V_d_hat = arma::as_scalar(counts.t() * hD_unique * counts) / (double(n) * n);
  double d_c_hat = (V_d_hat > 0) ? V_c_hat / V_d_hat : 0.0;

  double kappa_hat = (d_c_hat < 1) ? 1.0 - d_hat / d_c_hat : 0.0;

  // 4. Calculate influence functions efficiently
  arma::mat hC_sym_unique = (hC_unique + hC_unique.t()) / 2.0;
  arma::mat hD_sym_unique = (hD_unique + hD_unique.t()) / 2.0;

  arma::vec g_c_hat_unique = (hC_sym_unique * counts) / double(n);
  arma::vec g_d_hat_unique = (hD_sym_unique * counts) / double(n);

  arma::vec if_kappa(n);

  for(int i = 0; i < n; ++i){
    int u = inverse_indices(i);

    double if_d_i = (B_bar > 0) ? (A_unique(u) - d_hat * B_unique(u)) / B_bar : 0.0;

    double g_c_hat_i = g_c_hat_unique(u);
    double g_d_hat_i = g_d_hat_unique(u);
    double if_dc_numerator = 2 * (g_c_hat_i - V_c_hat) - 2 * d_c_hat * (g_d_hat_i - V_d_hat);
    double if_dc_i = (V_d_hat > 0) ? if_dc_numerator / V_d_hat : 0.0;

    if (d_c_hat > 0){
      if_kappa(i) = - ( (1.0 / d_c_hat) * if_d_i - (d_hat / (d_c_hat * d_c_hat)) * if_dc_i );
    } else {
      if_kappa(i) = 0.0;
    }
  }

  // 5. Calculate final variance and CI
  double var_kappa = arma::sum(arma::pow(if_kappa, 2)) / (double(n) * n);
  double se_kappa = std::sqrt(var_kappa);

  double alpha = 1.0 - conf_level;
  double z_crit = R::qnorm(1.0 - alpha / 2.0, 0.0, 1.0, true, false);
  double ci_lower = kappa_hat - z_crit * se_kappa;
  double ci_upper = kappa_hat + z_crit * se_kappa;

  return Rcpp::List::create(
    Rcpp::_["kappa"] = kappa_hat,
    Rcpp::_["se"] = se_kappa,
    Rcpp::_["ci"] = Rcpp::NumericVector::create(ci_lower, ci_upper),
    Rcpp::_["if_vals"] = if_kappa
  );
}
