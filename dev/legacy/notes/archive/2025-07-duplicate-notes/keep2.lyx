\begin_layout Plain Layout


\backslash
caption{Maximum Likelihood Estimation of Fleiss' Kappa with Missing Data via EM}
\end_layout

\begin_layout Plain Layout


\backslash
label{alg:em_kappa}
\end_layout

\begin_layout Plain Layout


\backslash
begin{algorithmic}[1]
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textbf{Input:} Data matrix $
\backslash
mathbf{X}$ ($n 
\backslash
times c$),
 number of raters $r$,
 number of categories $c$,
 loss matrix $
\backslash
mathbf{L}$ ($c 
\backslash
times c$).
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textbf{Output:} Kappa estimate $
\backslash
hat{
\backslash
kappa}$,
 Variance estimate $
\backslash
widehat{
\backslash
text{Var}}(
\backslash
hat{
\backslash
kappa})$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
Hrule
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textbf{Procedure 1:
 Preprocessing}
\end_layout

\begin_layout Plain Layout


\backslash
STATE Group rows of $
\backslash
mathbf{X}$ into $n_{unique}$ unique observed patterns $
\backslash
mathbf{x}_u$ with counts $n_u$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE For each $
\backslash
mathbf{x}_u$,
 compute the number of missing ratings $s_u = r - 
\backslash
sum_{j=1}^c x_{uj}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Generate the set of all possible completion patterns $
\backslash
mathcal{C}_u$ for each $
\backslash
mathbf{x}_u$ by finding all compositions of $s_u$ into $c$ parts.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Compute the global lexicographical rank for every possible complete pattern across all $
\backslash
mathcal{C}_u$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Construct a dense mapping from the set of these $m_{active}$ unique ranks to local indices $j 
\backslash
in 
\backslash
{1,
 
\backslash
dots,
 m_{active}
\backslash
}$.
 Store this mapping as `idx_to_rank`.
\end_layout

\begin_layout Plain Layout


\backslash
STATE For each group $u$,
 create a list of the local indices of its completion patterns,
 `completion_indices$_u$`.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Store the preprocessed data structure containing all `completion_indices$_u$`,
 group counts $n_u$,
 and the `idx_to_rank` map.
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
Hrule
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textbf{Procedure 2:
 Initialization (Smoothed Smart Start)}
\end_layout

\begin_layout Plain Layout


\backslash
STATE Initialize a preliminary parameter vector $
\backslash
boldsymbol{
\backslash
theta}_{prelim}$ of length $m_{active}$ with a small constant $
\backslash
alpha$ (e.g.,
 $10^{-4}$).
\end_layout

\begin_layout Plain Layout


\backslash
STATE For each unique group $u$ that is already complete ($s_u = 0$),
 add its count $n_u$ to the corresponding element of $
\backslash
boldsymbol{
\backslash
theta}_{prelim}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Normalize:
 $
\backslash
boldsymbol{
\backslash
theta}_{prelim} 
\backslash
leftarrow 
\backslash
boldsymbol{
\backslash
theta}_{prelim} / 
\backslash
sum 
\backslash
boldsymbol{
\backslash
theta}_{prelim}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Perform a single E-step:
 for each group $u$,
 calculate posterior probabilities $
\backslash
tau_{uk}$ for each completion $k 
\backslash
in 
\backslash
mathcal{C}_u$ proportionally to $
\backslash
boldsymbol{
\backslash
theta}_{prelim}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Perform a single M-step:
 sum the expected counts across all groups to get a final starting vector $
\backslash
boldsymbol{
\backslash
theta}^{(0)}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
Hrule
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textbf{Procedure 3:
 EM Iteration}
\end_layout

\begin_layout Plain Layout


\backslash
STATE Initialize $
\backslash
boldsymbol{
\backslash
theta} 
\backslash
leftarrow 
\backslash
boldsymbol{
\backslash
theta}^{(0)}$.
\end_layout

\begin_layout Plain Layout


\backslash
FOR{$t = 1$ to $max
\backslash
_iter$}
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textit{// E-step:}
\end_layout

\begin_layout Plain Layout


\backslash
STATE For each group $u$,
 compute the denominator for the posterior:
 $W_u = 
\backslash
sum_{k 
\backslash
in 
\backslash
mathcal{C}_u} 
\backslash
theta_k^{(t-1)}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textit{// M-step:}
\end_layout

\begin_layout Plain Layout


\backslash
STATE Compute expected counts for each active parameter $j$:
 $E_j = 
\backslash
sum_{u} n_u 
\backslash
sum_{k 
\backslash
in 
\backslash
mathcal{C}_u,
 k=j} 
\backslash
frac{
\backslash
theta_k^{(t-1)}}{W_u}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Update parameters:
 $
\backslash
theta_j^{(t)} 
\backslash
leftarrow E_j / n$.
\end_layout

\begin_layout Plain Layout


\backslash
IF{$
\backslash
max_j |
\backslash
theta_j^{(t)} - 
\backslash
theta_j^{(t-1)}| < 
\backslash
text{tolerance}$}
\end_layout

\begin_layout Plain Layout


\backslash
STATE Set `converged=TRUE` and 
\backslash
textbf{break}.
\end_layout

\begin_layout Plain Layout


\backslash
ENDIF
\end_layout

\begin_layout Plain Layout


\backslash
ENDFOR
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
Hrule
\end_layout

\begin_layout Plain Layout


\backslash
STATE 
\backslash
textbf{Procedure 4:
 Variance and Kappa Calculation}
\end_layout

\begin_layout Plain Layout


\backslash
STATE Prune the converged $
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}$ by removing elements smaller than a tolerance (e.g.,
 $10^{-9}$),
 resulting in a final,
 dense vector $
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final}$ of length $m_{final}$.
 Renormalize $
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Select a reference parameter $k_{ref}$ corresponding to the largest element of $
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Re-calculate the posterior probabilities $
\backslash
tau_{uk}$ for each group $u$ using only the $m_{final}$ parameters in $
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE For each group $u$,
 compute the reduced conditional score vector $
\backslash
mathbf{s}_u^*$ of size $(m_{final}-1)$ where the $j$-th element is $(
\backslash
tau_{uj}/
\backslash
hat{
\backslash
theta}_j) - (
\backslash
tau_{uk_{ref}}/
\backslash
hat{
\backslash
theta}_{k_{ref}})$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Compute the $(m_{final}-1) 
\backslash
times (m_{final}-1)$ information matrix $
\backslash
mathbf{I}^* = 
\backslash
sum_u n_u 
\backslash
mathbf{s}_u^* (
\backslash
mathbf{s}_u^*)^T$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Enforce symmetry:
 $
\backslash
mathbf{I}^* 
\backslash
leftarrow 0.5(
\backslash
mathbf{I}^* + (
\backslash
mathbf{I}^*)^T)$.
 Invert to get $
\backslash
mathbf{V}^* = (
\backslash
mathbf{I}^*)^{-1}$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Construct the $m_{final} 
\backslash
times (m_{final}-1)$ Jacobian matrix $
\backslash
mathbf{J}$ for the re-parameterization.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Compute the final $m_{final} 
\backslash
times m_{final}$ covariance matrix $
\backslash
widehat{
\backslash
text{Var}}(
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final}) = 
\backslash
mathbf{J} 
\backslash
mathbf{V}^* 
\backslash
mathbf{J}^T$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Generate the constant matrices $
\backslash
mathbf{K}_{final}$ and $
\backslash
mathbf{d}_{final}$ corresponding to the $m_{final}$ active patterns.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Compute $
\backslash
hat{
\backslash
kappa} = g(
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final})$ and its gradient $
\backslash
nabla g$.
\end_layout

\begin_layout Plain Layout


\backslash
STATE Compute the final variance $
\backslash
widehat{
\backslash
text{Var}}(
\backslash
hat{
\backslash
kappa}) = (
\backslash
nabla g)^T 
\backslash
widehat{
\backslash
text{Var}}(
\backslash
hat{
\backslash
boldsymbol{
\backslash
theta}}_{final}) (
\backslash
nabla g)$.
\end_layout

\begin_layout Plain Layout


\backslash
end{algorithmic}
\end_layout

