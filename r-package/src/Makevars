# The C++ library is vendored into this directory by dev/vendor-cpp.sh (run via
# `just vendor`), so the package is self-contained: no reach-up to ../../include
# and no prebuilt static library. R compiles every *.cpp here and links them
# together. Do NOT edit the vendored *.cpp / misskappa/*.hpp — edit the canonical
# sources under <repo>/src and <repo>/include and re-run `just vendor`.

CXX_STD = CXX17

# -I. resolves the vendored "misskappa/..." and "detail_..." headers. Eigen comes
# from RcppEigen (LinkingTo). EIGEN_NO_EXCEPTIONS matches how the library is built.
PKG_CPPFLAGS = -I. -DEIGEN_NO_EXCEPTIONS
