# Link against the prebuilt opt-preset libmisskappa.a so a header change forces
# the R glue to recompile against the new ABI. Build the lib first with
# `cmake --preset opt && cmake --build --preset opt` (or `just opt`).

CXX_STD = CXX23

MISSKAPPA_INCLUDE ?= $(CURDIR)/../../include
MISSKAPPA_LIB ?= $(CURDIR)/../../build-opt/libmisskappa.a

PKG_CPPFLAGS = -I$(MISSKAPPA_INCLUDE) -DEIGEN_NO_EXCEPTIONS
PKG_LIBS = $(MISSKAPPA_LIB)

# Force the R glue to relink when the static library changes.
$(SHLIB): $(MISSKAPPA_LIB)
