# The C++ library is vendored into this directory by dev/vendor-cpp.sh (run via
# `just vendor`), so the package is self-contained: no reach-up to ../../include
# and no prebuilt static library. R compiles every *.cpp here and links them
# together. Do NOT edit the vendored *.cpp / misskappa/*.hpp — edit the canonical
# sources under <repo>/src and <repo>/include and re-run `just vendor`.

CXX_STD = CXX17

# -I. resolves the qualified "misskappa/..." headers; -Imisskappa resolves the
# unqualified "detail_..." impl headers, which are vendored under misskappa/ so the
# src/ top level holds only *.cpp (R CMD check flags stray top-level headers).
# Eigen comes from RcppEigen (LinkingTo); EIGEN_NO_EXCEPTIONS matches the library.
PKG_CPPFLAGS = -I. -Imisskappa -DEIGEN_NO_EXCEPTIONS
