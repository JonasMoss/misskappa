# Paper build is paper/-local; paper/.gitignore handles its own outputs.

# Quarto render byproducts (README.md is the tracked gfm output)
/README.html
/README_files/
.quarto/

# Private WIP papers (separate private repo, nested here for workflow)
papers/00_wip/

# Local-only dev material — NEVER push (third-party copyrighted PDFs, the
# vendored irrCAC smoke oracle, and raw datasets). Kept on disk for local
# work; purged from history on 2026-06-09.
dev/refs/
dev/irrcacsmoke/
dev/dat/

# Experiment result data — regenerated from the seeded runners. Each
# experiment's runner + report.qmd is tracked (the recipe); the CSV outputs
# are not, keeping the public tree lean. Each results/ dir keeps its own
# .gitignore so the directory persists.
experiments/**/results/*.csv
