# Paper-local recipes for kappa-missing.tex.

set shell := ["bash", "-euo", "pipefail", "-c"]

slug := "kappa-missing"

default:
  @just --list

# Build the manuscript PDF.
pdf:
  @latexmk -pdf -interaction=nonstopmode {{slug}}.tex

# Run one simulation by short name. Scripts live in scripts/.
sim name:
  @Rscript scripts/{{name}}.R

# Run every simulation. Hours-scale.
sims:
  @for s in scripts/*.R; do echo "=== $s ==="; Rscript "$s"; done

# Rebuild tables/ from curated results/ CSVs.
tables:
  @Rscript scripts/build_tables.R

# Rebuild figures/ from curated results/ CSVs.
figures:
  @Rscript scripts/build_figures.R

# Cheap pipeline: tables + figures + pdf, no sims.
paper: tables figures pdf

# Bundle the archive-bound subset for OSF.
archive:
  @echo "TODO: implement archive bundling per claude_new/AGENTS.md"

clean:
  @latexmk -C {{slug}}.tex || true
  @rm -f {{slug}}.bbl {{slug}}.run.xml
