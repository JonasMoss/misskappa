// kappa_raw_cpp.cpp -----------------------------------------------------------
//   Compute Conger, Fleiss and Brennan–Prediger kappas from raw ratings and
//   give influence‑function standard errors.  Single entry‑point, no CIs.
//
//   Parameters
//     x         : integer matrix n × R (NA_INT for missing)
//     loss_type : 1=nominal, 2=absolute, 3=quadratic
//     ipw       : TRUE ⇒ inverse‑probability weights 1/π_j ; FALSE ⇒ AC
//     eps       : lower bound for π_j when ipw (winsor)
// ---------------------------------------------------------------------------
// [[Rcpp::depends(RcppArmadillo)]]
#include <RcppArmadillo.h>
#include <unordered_map>
#include <set>
#include <functional>

constexpr int NA_INT = -2147483648;   // R's NA_INTEGER sentinel

// loss helpers ---------------------------------------------------------------
inline double loss_nominal(int a,int b){return a==b?0.0:1.0;}
inline double loss_abs(int a,int b){return std::abs(a-b);}
inline double loss_quad(int a,int b){double d=double(a-b);return d*d;}
using LossFun = std::function<double(int,int)>;

// ---------------------------------------------------------------------------
// [[Rcpp::export]]
Rcpp::List kappa_raw_cpp2(const arma::imat& x,
                         int  loss_type = 1,
                         bool ipw       = false,
                         double eps     = 0.0){
  const int n = x.n_rows;
  const int R = x.n_cols;
  if(R<2) Rcpp::stop("Need at least 2 raters");

  // choose loss --------------------------------------------------------------
  LossFun loss;
  switch(loss_type){
  case 1: loss = loss_nominal; break;
  case 2: loss = loss_abs;     break;
  case 3: loss = loss_quad;    break;
  default: Rcpp::stop("loss_type must be 1,2,3");
  }

  // collect categories -------------------------------------------------------
  std::set<int> cat_set;
  for(int i=0;i<n;++i) for(int j=0;j<R;++j) if(x(i,j)!=NA_INT) cat_set.insert(x(i,j));
  const int K = cat_set.size();
  if(K==0) Rcpp::stop("No observed ratings");
  std::vector<int> cats(cat_set.begin(),cat_set.end());
  std::unordered_map<int,int> cat2idx; for(int k=0;k<K;++k) cat2idx[cats[k]]=k;

  // π_j ----------------------------------------------------------------------
  arma::vec pi_j(R,arma::fill::zeros);
  for(int j=0;j<R;++j) for(int i=0;i<n;++i) if(x(i,j)!=NA_INT) pi_j(j)+=1.0;
  pi_j/=n;
  for(int j=0;j<R;++j) if(pi_j(j)==0) Rcpp::stop("A rater has no data");
  if(ipw) for(int j=0;j<R;++j) pi_j(j)=std::max(pi_j(j),eps);

  // hash unique subjects -----------------------------------------------------
  struct VecHash{std::size_t operator()(const arma::ivec&v)const noexcept{
    std::size_t seed=v.n_elem;for(arma::uword i=0;i<v.n_elem;++i) seed^=v(i)+0x9e3779b9+(seed<<6)+(seed>>2);return seed;}};
  struct VecEq{bool operator()(const arma::ivec&a,const arma::ivec&b)const noexcept{return a.n_elem==b.n_elem&&arma::all(a==b);}};

  std::unordered_map<arma::ivec,int,VecHash,VecEq> row_map;
  arma::uvec inv_idx(n);
  std::vector<arma::ivec> uniq_rows;
  arma::uvec counts;
  for(int i=0;i<n;++i){
    arma::ivec key=x.row(i).t();
    auto it=row_map.find(key);
    if(it==row_map.end()){int id=uniq_rows.size();row_map[key]=id;uniq_rows.push_back(key);counts.resize(id+1);counts(id)=1;inv_idx(i)=id;}
    else{inv_idx(i)=it->second;counts(it->second)++;}
  }
  const int U=uniq_rows.size();
  arma::imat xU(U,R); for(int u=0;u<U;++u) xU.row(u)=uniq_rows[u].t();
  arma::umat MU=(xU!=NA_INT);

  // observed disagreement d --------------------------------------------------
  arma::vec Au(U,arma::fill::zeros), Bu(U,arma::fill::zeros);
  for(int u=0;u<U;++u){
    for(int j=0;j<R-1;++j) if(MU(u,j))
      for(int k=j+1;k<R;++k) if(MU(u,k)){
        double wj= ipw?1.0/pi_j(j):1.0;
        double wk= ipw?1.0/pi_j(k):1.0;
        double w = wj*wk;
        Bu(u)+=w;
        Au(u)+=w*loss(xU(u,j),xU(u,k));
      }
  }
  const double Abar = arma::dot(counts,Au)/n;
  const double Bbar = arma::dot(counts,Bu)/n;
  const double d_hat=Abar/Bbar;
  arma::vec IFd(n);
  for(int i=0;i<n;++i){int u=inv_idx(i);IFd(i)=(Au(u)-d_hat*Bu(u))/Bbar;}

  // Conger chance (cross‑subject) -------------------------------------------
  arma::mat Cu(U,U,arma::fill::zeros), Du(U,U,arma::fill::zeros);
  for(int u=0;u<U;++u)
    for(int v=0;v<U;++v)
      for(int j=0;j<R-1;++j) if(MU(u,j))
        for(int k=j+1;k<R;++k) if(MU(v,k)){
          double wj= ipw?1.0/pi_j(j):1.0;
          double wk= ipw?1.0/pi_j(k):1.0;
          double w=wj*wk;
          Du(u,v)+=w;
          Cu(u,v)+=w*loss(xU(u,j),xU(v,k));
        }
        const double Cbar=arma::as_scalar(counts.t()*Cu*counts)/(double(n)*n);
        const double Dbar=arma::as_scalar(counts.t()*Du*counts)/(double(n)*n);
        const double dC_conger=Cbar/Dbar;
        const double kappa_conger=1.0-d_hat/dC_conger;
        arma::mat Cu_sym=0.5*(Cu+Cu.t()), Du_sym=0.5*(Du+Du.t());
        arma::vec IF_conger(n);
        for(int i=0;i<n;++i){int u=inv_idx(i);
          double gC=arma::dot(Cu_sym.row(u),counts)/n;
          double gD=arma::dot(Du_sym.row(u),counts)/n;
          double IFdC=(2.0*(gC-Cbar)-2.0*dC_conger*(gD-Dbar))/Dbar;
          IF_conger(i)=-IFd(i)/dC_conger + d_hat*IFdC/(dC_conger*dC_conger);
        }
        const double se_conger=std::sqrt(arma::dot(IF_conger,IF_conger)/(double(n)*n));

        // pooled marginals for Fleiss --------------------------------------------
        std::vector<double> Nc(K,0.0); double total_w=0.0;
        for(int i=0;i<n;++i) for(int j=0;j<R;++j) if(x(i,j)!=NA_INT){
          double w= ipw?1.0/pi_j(j):1.0;
          total_w+=w; Nc[cat2idx[x(i,j)]]+=w; }
        arma::vec pc(K); for(int k=0;k<K;++k) pc(k)=Nc[k]/total_w;
        double dC_fleiss=0.0; for(int a=0;a<K;++a) for(int b=0;b<K;++b) dC_fleiss+=loss(cats[a],cats[b])*pc(a)*pc(b);
        const double kappa_fleiss=1.0-d_hat/dC_fleiss;
        arma::vec grad(K,arma::fill::zeros);
        for(int a=0;a<K;++a) for(int b=0;b<K;++b) grad(a)+=2.0*loss(cats[a],cats[b])*pc(b);

        // rating‑level IF for Fleiss ---------------------------------------------
        double sum_sq=0.0; std::size_t n_ratings=0;
        for(int i=0;i<n;++i){
          for(int j=0;j<R;++j){
            if(x(i,j)==NA_INT) continue;
            ++n_ratings;
            int cat=x(i,j);
            // observed‑disagreement part: average with other raters
            double Aij=0.0; int denom=0;
            for(int k=0;k<R;++k){ if(k==j||x(i,k)==NA_INT) continue; Aij+=loss(cat,x(i,k)); ++denom; }
            if(denom>0) Aij/=double(denom);
            double IFd_r=Aij-d_hat;                       // difference from global mean
            double IFdC_r=(grad(cat2idx[cat])-dC_fleiss)/total_w;
            double IFk_r=-IFd_r/dC_fleiss + d_hat*IFdC_r/(dC_fleiss*dC_fleiss);
            sum_sq+=IFk_r*IFk_r;
          }
        }
        const double se_fleiss=std::sqrt(sum_sq)/(double)n_ratings;

        // BP ----------------------------------------------------------------------
        double dC_bp=0.0; for(int a=0;a<K;++a) for(int b=0;b<K;++b) dC_bp+=loss(cats[a],cats[b]);
        dC_bp/=(double)K*(double)K;
        const double kappa_bp=1.0-d_hat/dC_bp;
        arma::vec IF_bp = -IFd/dC_bp; const double se_bp=std::sqrt(arma::dot(IF_bp,IF_bp)/(double(n)*n));

        // return ------------------------------------------------------------------
        return Rcpp::List::create(
          Rcpp::_["kappa_conger"] = kappa_conger,
          Rcpp::_["se_conger"]    = se_conger,
          Rcpp::_["kappa_fleiss"] = kappa_fleiss,
          Rcpp::_["se_fleiss"]   = se_fleiss,
          Rcpp::_["kappa_bp"]     = kappa_bp,
          Rcpp::_["se_bp"]       = se_bp
        );
}
